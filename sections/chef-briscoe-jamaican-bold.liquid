{% liquid
  assign shop_url = section.settings.shop_url | default: '/collections/all'
  assign experience_url = section.settings.full_site_url | default: 'https://briscoeskitchen.com'
  assign catering_url = section.settings.catering_url | default: experience_url
  assign recipes_url = section.settings.recipes_url | default: experience_url
  assign chef_services_url = section.settings.chef_services_url | default: catering_url
  assign contact_url = section.settings.contact_url | default: experience_url
  assign partnership_url = section.settings.partnership_url | default: contact_url
  assign phone_href = section.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' | prepend: 'tel:'

  assign display_title = section.settings.product_title
  assign display_price = section.settings.single_price
  assign display_description = section.settings.product_description
  assign hero_alt = section.settings.hero_image.alt | default: display_title
  assign product_alt = section.settings.product_image.alt | default: display_title

  if product
    assign display_title = product.title
    assign display_price = product.price | money
    assign display_description = product.description | strip_html | truncate: 220
  endif
%}

<section id="briscoe-product-shop-{{ section.id }}" class="bk-shop">
  <style>
    #shopify-section-{{ section.id }} {
      --black: #050505;
      --green: #007a3d;
      --green-bright: #00a352;
      --gold: #ffb900;
      --gold-light: #ffd050;
      --cream: #f7f2e8;
      --white: #ffffff;
      --ink: #111111;
      --line: #050505;
      color: var(--ink);
      font-family: Impact, Haettenschweiler, "Arial Narrow Bold", Arial, sans-serif;
    }

    #shopify-section-{{ section.id }} * { box-sizing: border-box; }
    #shopify-section-{{ section.id }} .bk-shop { background: var(--cream); overflow: hidden; }
    #shopify-section-{{ section.id }} .bk-wrap { width: min(1180px, calc(100% - 32px)); margin: 0 auto; }
    #shopify-section-{{ section.id }} h1,
    #shopify-section-{{ section.id }} h2,
    #shopify-section-{{ section.id }} h3,
    #shopify-section-{{ section.id }} p { margin: 0; }

    #shopify-section-{{ section.id }} .bk-top { background: var(--black); color: var(--gold); text-align: center; padding: 10px 16px; border-bottom: 4px solid var(--line); font-size: clamp(18px, 2.4vw, 30px); line-height: .95; text-transform: uppercase; }
    #shopify-section-{{ section.id }} .bk-nav { background: linear-gradient(180deg, var(--green-bright), var(--green)); border-bottom: 4px solid var(--line); }
    #shopify-section-{{ section.id }} .bk-nav-inner { min-height: 68px; display: flex; align-items: center; justify-content: space-between; gap: 18px; }
    #shopify-section-{{ section.id }} .bk-logo,
    #shopify-section-{{ section.id }} .bk-nav a { color: var(--gold-light); text-decoration: none; text-transform: uppercase; text-shadow: 2px 2px 0 rgba(0,0,0,.5); }
    #shopify-section-{{ section.id }} .bk-logo { display: inline-flex; align-items: center; gap: 12px; font-size: clamp(24px, 3vw, 40px); line-height: .9; -webkit-text-stroke: 1px var(--line); }
    #shopify-section-{{ section.id }} .bk-mark { width: 46px; height: 46px; display: grid; place-items: center; border: 3px solid var(--gold); border-radius: 50%; background: var(--black); color: var(--gold); font-size: 24px; line-height: 1; flex: 0 0 auto; }
    #shopify-section-{{ section.id }} .bk-links { display: flex; align-items: center; gap: clamp(12px, 1.7vw, 22px); font-size: clamp(15px, 1.45vw, 21px); line-height: 1; }
    #shopify-section-{{ section.id }} .bk-cart { min-width: 74px; min-height: 44px; display: grid; place-items: center; border: 3px solid var(--line); border-radius: 999px; background: var(--gold); color: var(--black) !important; text-shadow: none !important; box-shadow: 0 4px 0 rgba(0,0,0,.55); }

    #shopify-section-{{ section.id }} .bk-flag { background: linear-gradient(34deg, transparent 0 43%, var(--gold) 43% 48%, transparent 48% 52%, var(--gold) 52% 57%, transparent 57%), linear-gradient(146deg, var(--green) 0 48%, var(--black) 48% 52%, var(--green) 52% 100%); }
    #shopify-section-{{ section.id }} .bk-hero { min-height: 600px; display: grid; grid-template-columns: minmax(0, 1fr) minmax(340px, .86fr); border-bottom: 6px solid var(--line); color: var(--white); background-color: var(--black); }
    #shopify-section-{{ section.id }} .bk-hero-copy { display: flex; flex-direction: column; justify-content: center; padding: clamp(34px, 6vw, 76px); background: linear-gradient(90deg, var(--black) 0 82%, rgba(0,0,0,.15)); position: relative; z-index: 1; }
    #shopify-section-{{ section.id }} .bk-eyebrow,
    #shopify-section-{{ section.id }} .bk-section-kicker { color: var(--gold); font-size: clamp(18px, 2vw, 28px); line-height: 1; text-transform: uppercase; }
    #shopify-section-{{ section.id }} .bk-title { max-width: 820px; margin-top: 12px; color: var(--white); font-size: clamp(56px, 8.6vw, 124px); line-height: .78; text-transform: uppercase; text-shadow: 0 6px 0 rgba(0,0,0,.7), 0 16px 30px rgba(0,0,0,.6); }
    #shopify-section-{{ section.id }} .bk-title strong { display: block; color: var(--gold); font-family: Georgia, "Times New Roman", serif; font-style: italic; font-weight: 900; line-height: .9; text-transform: none; }
    #shopify-section-{{ section.id }} .bk-lead { max-width: 700px; margin-top: 18px; color: var(--gold-light); font-family: Arial, sans-serif; font-size: clamp(18px, 1.8vw, 27px); line-height: 1.2; font-weight: 900; }
    #shopify-section-{{ section.id }} .bk-actions { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 28px; }
    #shopify-section-{{ section.id }} .bk-btn,
    #shopify-section-{{ section.id }} button.bk-btn { min-height: 56px; display: inline-flex; align-items: center; justify-content: center; padding: 13px 24px; border: 3px solid var(--line); border-radius: 8px; background: linear-gradient(180deg, var(--gold-light), var(--gold)); color: var(--black); box-shadow: 0 5px 0 var(--line); font: inherit; font-size: clamp(18px, 1.8vw, 25px); line-height: .95; text-decoration: none; text-transform: uppercase; cursor: pointer; }
    #shopify-section-{{ section.id }} .bk-btn--green { background: linear-gradient(180deg, var(--green-bright), var(--green)); color: var(--gold-light); }
    #shopify-section-{{ section.id }} .bk-btn--dark { background: var(--black); color: var(--gold); }

    #shopify-section-{{ section.id }} .bk-hero-art { min-height: 600px; display: grid; place-items: center; padding: 44px 24px; overflow: hidden; }
    #shopify-section-{{ section.id }} .bk-product-stack { position: relative; width: min(430px, 78vw); aspect-ratio: 1 / 1.08; display: grid; place-items: center; }
    #shopify-section-{{ section.id }} .bk-spice-swoosh { position: absolute; width: 118%; height: 42%; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.9) 0 1px, transparent 2px) 0 0 / 22px 22px, linear-gradient(90deg, transparent, #f16d12 22%, var(--gold) 54%, transparent); filter: drop-shadow(0 0 12px rgba(255,203,5,.68)); transform: rotate(-18deg); }
    #shopify-section-{{ section.id }} .bk-bottle { position: relative; width: min(190px, 42vw); height: 360px; border: 4px solid var(--line); border-radius: 20px 20px 32px 32px; background: linear-gradient(90deg, rgba(255,255,255,.36), transparent 20% 70%, rgba(0,0,0,.22)), repeating-linear-gradient(0deg, #c86b18 0 6px, #f5a82a 6px 12px); box-shadow: 22px 30px 0 rgba(0,0,0,.38), 0 0 38px rgba(255,203,5,.36); overflow: hidden; transform: rotate(12deg); }
    #shopify-section-{{ section.id }} .bk-bottle::before { content: ""; position: absolute; left: 30px; right: 30px; top: -35px; height: 78px; border: 4px solid var(--line); border-radius: 16px 16px 8px 8px; background: #141414; }
    #shopify-section-{{ section.id }} .bk-label { position: absolute; left: 14px; right: 14px; top: 106px; min-height: 150px; display: grid; place-items: center; padding: 12px 8px; border: 4px solid var(--line); background: linear-gradient(34deg, transparent 0 43%, var(--gold) 43% 49%, transparent 49% 51%, var(--gold) 51% 57%, transparent 57%), linear-gradient(146deg, var(--green) 0 48%, var(--black) 48% 52%, var(--green) 52% 100%); color: var(--gold); text-align: center; text-transform: uppercase; font-size: 36px; line-height: .82; text-shadow: 2px 2px 0 var(--black); }
    #shopify-section-{{ section.id }} .bk-label small { display: block; margin-top: 7px; color: var(--white); font-size: 13px; }

    #shopify-section-{{ section.id }} .bk-marquee { background: var(--gold); color: var(--black); border-bottom: 6px solid var(--line); overflow: hidden; }
    #shopify-section-{{ section.id }} .bk-marquee-track { display: flex; width: max-content; animation: bkMove-{{ section.id }} 24s linear infinite; white-space: nowrap; }
    #shopify-section-{{ section.id }} .bk-marquee span { display: inline-flex; align-items: center; gap: 20px; padding: 14px 22px; font-size: clamp(22px, 2.8vw, 38px); line-height: 1; text-transform: uppercase; }
    #shopify-section-{{ section.id }} .bk-marquee span::after { content: ""; width: 12px; height: 12px; border-radius: 50%; background: var(--black); }
    @keyframes bkMove-{{ section.id }} { to { transform: translateX(-50%); } }

    #shopify-section-{{ section.id }} .bk-product,
    #shopify-section-{{ section.id }} .bk-details,
    #shopify-section-{{ section.id }} .bk-faq { padding: 58px 0; background: var(--cream); border-top: 6px solid var(--line); }
    #shopify-section-{{ section.id }} .bk-product-grid { display: grid; grid-template-columns: minmax(320px, .95fr) minmax(320px, 1fr); gap: 36px; align-items: start; }
    #shopify-section-{{ section.id }} .bk-product-media { min-height: 440px; display: grid; place-items: center; border: 4px solid var(--line); border-radius: 10px; background: radial-gradient(circle at 30% 35%, rgba(255,203,5,.4), transparent 24%), linear-gradient(34deg, transparent 0 43%, var(--gold) 43% 48%, transparent 48% 52%, var(--gold) 52% 57%, transparent 57%), #f5e6be; overflow: hidden; }
    #shopify-section-{{ section.id }} .bk-product-media img,
    #shopify-section-{{ section.id }} .bk-hero-art img { width: 100%; height: 100%; display: block; object-fit: cover; }
    #shopify-section-{{ section.id }} .bk-breadcrumb { color: var(--green); font-size: 18px; text-transform: uppercase; }
    #shopify-section-{{ section.id }} .bk-product-title { margin-top: 4px; color: var(--black); font-size: clamp(50px, 5.6vw, 82px); line-height: .82; text-transform: uppercase; text-shadow: 0 3px 0 rgba(255,203,5,.55); }
    #shopify-section-{{ section.id }} .bk-underline { display: block; width: min(520px, 100%); height: 10px; margin: 8px 0 6px; border-radius: 999px; background: var(--gold); }
    #shopify-section-{{ section.id }} .bk-product-sub { color: var(--green); font-family: Georgia, "Times New Roman", serif; font-style: italic; font-size: clamp(26px, 3vw, 40px); line-height: 1; font-weight: 900; }
    #shopify-section-{{ section.id }} .bk-review { margin-top: 10px; color: #d89b00; font-family: Arial, sans-serif; font-size: 18px; font-weight: 900; }
    #shopify-section-{{ section.id }} .bk-review span { color: var(--black); font-size: 15px; }
    #shopify-section-{{ section.id }} .bk-price { margin-top: 8px; color: var(--black); font-size: clamp(42px, 5vw, 62px); line-height: .9; }
    #shopify-section-{{ section.id }} .bk-desc,
    #shopify-section-{{ section.id }} .bk-note,
    #shopify-section-{{ section.id }} .bk-copy { color: var(--black); font-family: Arial, sans-serif; font-size: 18px; line-height: 1.32; font-weight: 900; }
    #shopify-section-{{ section.id }} .bk-pack-label { display: block; margin-top: 18px; color: var(--black); font-size: 20px; text-transform: uppercase; }
    #shopify-section-{{ section.id }} .bk-packs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 8px; }
    #shopify-section-{{ section.id }} .bk-pack { min-height: 78px; display: grid; place-items: center; padding: 10px 12px; border: 4px solid var(--line); border-radius: 16px; background: var(--cream); color: var(--black); text-align: center; font-size: 20px; line-height: .96; box-shadow: 0 4px 0 rgba(0,0,0,.2); text-decoration: none; text-transform: uppercase; }
    #shopify-section-{{ section.id }} .bk-pack span { display: block; margin-top: 6px; font-family: Arial, sans-serif; font-size: 13px; line-height: 1.1; font-weight: 900; text-transform: none; }
    #shopify-section-{{ section.id }} .bk-pack--green { background: var(--green); color: var(--white); }
    #shopify-section-{{ section.id }} .bk-pack--gold { background: var(--gold); }
    #shopify-section-{{ section.id }} .bk-buy-row { display: grid; grid-template-columns: 120px minmax(0, 1fr); gap: 12px; margin-top: 16px; }
    #shopify-section-{{ section.id }} .bk-qty { min-height: 58px; width: 100%; border: 4px solid var(--line); border-radius: 8px; background: var(--white); color: var(--black); font: 900 22px/1 Arial, sans-serif; text-align: center; }
    #shopify-section-{{ section.id }} .bk-cart-btn { min-height: 58px; display: grid; place-items: center; border: 4px solid var(--line); border-radius: 8px; background: var(--green); color: var(--gold); box-shadow: 0 5px 0 var(--line); font: inherit; font-size: clamp(20px, 2.3vw, 30px); line-height: .95; text-transform: uppercase; text-decoration: none; }
    #shopify-section-{{ section.id }} .bk-trust { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 18px; }
    #shopify-section-{{ section.id }} .bk-trust-item { display: grid; grid-template-columns: 42px 1fr; gap: 8px; align-items: center; color: var(--black); font-family: Arial, sans-serif; font-size: 13px; font-weight: 900; line-height: 1.04; }
    #shopify-section-{{ section.id }} .bk-icon { width: 42px; height: 42px; display: grid; place-items: center; border: 3px solid var(--gold); border-radius: 50%; background: var(--black); color: var(--gold); font-family: Arial, sans-serif; font-size: 12px; }

    #shopify-section-{{ section.id }} .bk-catalog,
    #shopify-section-{{ section.id }} .bk-services,
    #shopify-section-{{ section.id }} .bk-community,
    #shopify-section-{{ section.id }} .bk-partners { padding: 62px 0; border-top: 6px solid var(--line); text-align: center; }
    #shopify-section-{{ section.id }} .bk-catalog { background: var(--green); color: var(--white); }
    #shopify-section-{{ section.id }} .bk-services { background: var(--black); color: var(--white); }
    #shopify-section-{{ section.id }} .bk-community { background: var(--black); color: var(--white); }
    #shopify-section-{{ section.id }} .bk-partners { background: var(--cream); color: var(--black); }
    #shopify-section-{{ section.id }} .bk-section-title { margin-top: 8px; color: inherit; font-size: clamp(42px, 5.6vw, 82px); line-height: .88; text-transform: uppercase; text-shadow: 0 5px 0 rgba(0,0,0,.22); }
    #shopify-section-{{ section.id }} .bk-section-sub { margin: 14px auto 0; max-width: 860px; color: var(--gold-light); font-family: Arial, sans-serif; font-size: clamp(18px, 2vw, 24px); font-weight: 900; line-height: 1.28; }
    #shopify-section-{{ section.id }} .bk-card-grid,
    #shopify-section-{{ section.id }} .bk-detail-grid,
    #shopify-section-{{ section.id }} .bk-faq-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-top: 30px; }
    #shopify-section-{{ section.id }} .bk-detail-grid,
    #shopify-section-{{ section.id }} .bk-faq-grid { grid-template-columns: repeat(3, 1fr); }
    #shopify-section-{{ section.id }} .bk-card,
    #shopify-section-{{ section.id }} .bk-detail,
    #shopify-section-{{ section.id }} .bk-faq-item { border: 5px solid var(--line); border-radius: 12px; background: var(--cream); color: var(--black); text-align: left; box-shadow: 0 8px 0 rgba(0,0,0,.32); text-decoration: none; overflow: hidden; }
    #shopify-section-{{ section.id }} .bk-card { min-height: 230px; display: flex; flex-direction: column; justify-content: flex-end; background: radial-gradient(circle at 42% 28%, rgba(255,255,255,.35), transparent 23%), linear-gradient(135deg, #6d3b16, #f7b73d 48%, #1d5c2a); color: var(--gold); }
    #shopify-section-{{ section.id }} .bk-card strong { display: block; padding: 14px 10px; background: var(--black); font-size: clamp(22px, 2.3vw, 34px); line-height: .92; text-transform: uppercase; }
    #shopify-section-{{ section.id }} .bk-card span,
    #shopify-section-{{ section.id }} .bk-detail p,
    #shopify-section-{{ section.id }} .bk-faq-item p { color: inherit; font-family: Arial, sans-serif; font-size: 15px; line-height: 1.28; font-weight: 900; }
    #shopify-section-{{ section.id }} .bk-detail,
    #shopify-section-{{ section.id }} .bk-faq-item { padding: 20px; }
    #shopify-section-{{ section.id }} .bk-detail h3,
    #shopify-section-{{ section.id }} .bk-faq-item h3 { color: var(--green); font-size: clamp(24px, 2.5vw, 34px); line-height: .96; text-transform: uppercase; margin-bottom: 10px; }

    #shopify-section-{{ section.id }} .bk-signup { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, .72fr) auto; gap: 12px; width: min(920px, 100%); margin: 28px auto 0; }
    #shopify-section-{{ section.id }} .bk-signup input { min-height: 62px; border: 4px solid var(--gold); border-radius: 8px; padding: 12px 18px; color: var(--black); background: var(--white); font: 900 20px/1 Arial, sans-serif; }
    #shopify-section-{{ section.id }} .bk-disclaimer { max-width: 760px; margin: 14px auto 0; color: var(--cream); font-family: Arial, sans-serif; font-size: 13px; line-height: 1.35; font-weight: 700; }

    #shopify-section-{{ section.id }} .bk-footer { padding: 42px 0 0; background: linear-gradient(180deg, var(--green-bright), var(--green)); color: var(--white); border-top: 6px solid var(--line); }
    #shopify-section-{{ section.id }} .bk-footer-grid { display: grid; grid-template-columns: 1.2fr repeat(3, 1fr); gap: 32px; padding-bottom: 40px; }
    #shopify-section-{{ section.id }} .bk-footer h3 { color: var(--gold); font-size: 30px; line-height: 1; text-transform: uppercase; }
    #shopify-section-{{ section.id }} .bk-footer p,
    #shopify-section-{{ section.id }} .bk-footer a { color: var(--white); font-family: Arial, sans-serif; font-size: 16px; line-height: 1.35; font-weight: 900; text-decoration: none; }
    #shopify-section-{{ section.id }} .bk-footer ul { display: grid; gap: 10px; list-style: none; margin: 14px 0 0; padding: 0; }
    #shopify-section-{{ section.id }} .bk-footer-bottom { padding: 12px 16px; border-top: 6px solid var(--black); background: var(--gold); color: var(--black); text-align: center; font-size: 18px; line-height: 1.1; }
    #shopify-section-{{ section.id }} .bk-sticky { display: none; }

    @media (max-width: 990px) {
      #shopify-section-{{ section.id }} .bk-hero,
      #shopify-section-{{ section.id }} .bk-product-grid,
      #shopify-section-{{ section.id }} .bk-detail-grid,
      #shopify-section-{{ section.id }} .bk-faq-grid,
      #shopify-section-{{ section.id }} .bk-footer-grid { grid-template-columns: 1fr; }
      #shopify-section-{{ section.id }} .bk-card-grid,
      #shopify-section-{{ section.id }} .bk-trust { grid-template-columns: repeat(2, 1fr); }
      #shopify-section-{{ section.id }} .bk-links { display: none; }
    }

    @media (max-width: 640px) {
      #shopify-section-{{ section.id }} .bk-wrap { width: min(100% - 24px, 1180px); }
      #shopify-section-{{ section.id }} .bk-hero,
      #shopify-section-{{ section.id }} .bk-hero-art { min-height: auto; }
      #shopify-section-{{ section.id }} .bk-hero-copy { padding: 34px 18px; }
      #shopify-section-{{ section.id }} .bk-title { font-size: clamp(52px, 17vw, 74px); }
      #shopify-section-{{ section.id }} .bk-packs,
      #shopify-section-{{ section.id }} .bk-buy-row,
      #shopify-section-{{ section.id }} .bk-card-grid,
      #shopify-section-{{ section.id }} .bk-trust,
      #shopify-section-{{ section.id }} .bk-signup { grid-template-columns: 1fr; }
      #shopify-section-{{ section.id }} .bk-actions,
      #shopify-section-{{ section.id }} .bk-btn,
      #shopify-section-{{ section.id }} .bk-cart-btn { width: 100%; }
      #shopify-section-{{ section.id }} .bk-product-media { min-height: 320px; }
      #shopify-section-{{ section.id }} .bk-sticky { position: fixed; left: 8px; right: 8px; bottom: 8px; z-index: 20; display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; padding: 7px; border: 2px solid var(--gold); border-radius: 8px; background: rgba(0,0,0,.9); }
      #shopify-section-{{ section.id }} .bk-sticky a { min-height: 42px; display: grid; place-items: center; border-radius: 6px; background: var(--gold); color: var(--black); font-size: 12px; text-decoration: none; text-transform: uppercase; }
      #shopify-section-{{ section.id }} .bk-sticky a:nth-child(2) { background: var(--green); color: var(--white); }
    }
  </style>

  <div class="bk-top">{{ section.settings.announcement }}</div>

  <nav class="bk-nav" aria-label="Main navigation">
    <div class="bk-wrap bk-nav-inner">
      <a class="bk-logo" href="{{ routes.root_url }}"><span class="bk-mark">B</span><span>{{ section.settings.brand_name }}</span></a>
      <div class="bk-links">
        <a href="{{ shop_url }}">Shop</a>
        <a href="{{ recipes_url }}">Recipes</a>
        <a href="{{ catering_url }}">Catering</a>
        <a href="{{ chef_services_url }}">Chef Services</a>
        <a href="{{ partnership_url }}">Brand Partnerships</a>
        <a href="{{ contact_url }}">Contact</a>
      </div>
      <a class="bk-cart" href="{{ routes.cart_url }}">Cart</a>
    </div>
  </nav>

  <div class="bk-hero bk-flag">
    <div class="bk-hero-copy">
      <p class="bk-eyebrow">{{ section.settings.hero_kicker }}</p>
      <h1 class="bk-title">{{ section.settings.hero_heading }}</h1>
      <p class="bk-lead">{{ section.settings.hero_text }}</p>
      <div class="bk-actions">
        <a class="bk-btn" href="{{ shop_url }}">Shop Island Gold</a>
        <a class="bk-btn bk-btn--green" href="{{ recipes_url }}">Explore Recipes</a>
        <a class="bk-btn bk-btn--dark" href="{{ catering_url }}">Book Catering</a>
      </div>
    </div>

    <div class="bk-hero-art">
      {% if section.settings.hero_image != blank %}
        <div class="bk-product-stack">
          <span class="bk-spice-swoosh"></span>
          {{ section.settings.hero_image | image_url: width: 900 | image_tag: loading: 'eager', alt: hero_alt }}
        </div>
      {% else %}
        <div class="bk-product-stack" aria-label="{{ display_title }}">
          <span class="bk-spice-swoosh"></span>
          <div class="bk-bottle"><div class="bk-label">Island<br>Gold<small>Briscoe's Kitchen & Spice</small></div></div>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="bk-marquee" aria-hidden="true">
    <div class="bk-marquee-track">
      {% for i in (1..2) %}
        <span>Official Product Shop</span><span>Secure Product Checkout</span><span>Ships From The U.S.</span><span>Recipe-Friendly Flavor</span><span>Catering & Chef Services Available</span>
      {% endfor %}
    </div>
  </div>

  <div class="bk-product">
    <div class="bk-wrap bk-product-grid">
      <div class="bk-product-media">
        {% if product and product.featured_image != blank %}
          {{ product.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: product.title }}
        {% elsif section.settings.product_image != blank %}
          {{ section.settings.product_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: product_alt }}
        {% else %}
          <div class="bk-product-stack"><span class="bk-spice-swoosh"></span><div class="bk-bottle"><div class="bk-label">Island<br>Gold<small>All Purpose Seasoning</small></div></div></div>
        {% endif %}
      </div>

      <div>
        <div class="bk-breadcrumb">Featured Drop</div>
        <h2 class="bk-product-title">{{ display_title }}</h2>
        <span class="bk-underline"></span>
        <div class="bk-product-sub">{{ section.settings.product_subtitle }}</div>
        {% if section.settings.review_count != blank %}<div class="bk-review">&#9733;&#9733;&#9733;&#9733;&#9733; <span>{{ section.settings.review_count }}</span></div>{% endif %}
        <div class="bk-price">{{ display_price }}</div>
        <p class="bk-desc">{{ display_description }}</p>

        <span class="bk-pack-label">Choose Your Pack</span>
        <div class="bk-packs">
          <a class="bk-pack" href="{{ shop_url }}"><strong>Single Bottle</strong><span>Perfect for first-time flavor lovers. {{ section.settings.single_price }}</span></a>
          <a class="bk-pack bk-pack--green" href="{{ shop_url }}"><strong>3-Pack</strong><span>Stock up for the kitchen, cookouts, and family meals. {{ section.settings.three_pack_price }}</span></a>
          <a class="bk-pack bk-pack--gold" href="{{ shop_url }}"><strong>Case Pack</strong><span>Best value for serious flavor lovers. {{ section.settings.case_price }}</span></a>
        </div>

        {% if product and product.available %}
          {% form 'product', product %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <div class="bk-buy-row">
              <input class="bk-qty" type="number" name="quantity" value="1" min="1" aria-label="Quantity">
              <button class="bk-cart-btn" type="submit">Add To Cart - {{ product.selected_or_first_available_variant.price | money }}</button>
            </div>
          {% endform %}
        {% else %}
          <div class="bk-buy-row">
            <input class="bk-qty" type="number" value="1" min="1" aria-label="Quantity">
            <a class="bk-cart-btn" href="{{ shop_url }}">Shop Products</a>
          </div>
        {% endif %}

        <p class="bk-note" style="margin-top:14px;color:var(--green);">Ships from the United States. Selected international shipping is available where supported.</p>
        <div class="bk-trust">
          <div class="bk-trust-item"><span class="bk-icon">SKU</span><span>Clean product catalog</span></div>
          <div class="bk-trust-item"><span class="bk-icon">Ship</span><span>Tracked fulfillment</span></div>
          <div class="bk-trust-item"><span class="bk-icon">Drop</span><span>Official product release</span></div>
          <div class="bk-trust-item"><span class="bk-icon">Lock</span><span>Secure checkout</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="bk-catalog">
    <div class="bk-wrap">
      <div class="bk-section-kicker">Curated Product Catalog</div>
      <h2 class="bk-section-title">Flavor Essentials Built For Direct Checkout</h2>
      <p class="bk-section-sub">Shop Briscoe's Kitchen & Spice seasonings, bundles, recipe add-ons, merch, and select product drops. For catering, private chef services, custom events, and personalized support, connect with the team through the service experience.</p>
      <div class="bk-card-grid">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <a class="bk-card" href="{{ block.settings.url | default: shop_url }}" {{ block.shopify_attributes }}><strong>{{ block.settings.title }}<br><span>{{ block.settings.subtitle }}</span></strong></a>
          {% endfor %}
        {% else %}
          <a class="bk-card" href="{{ shop_url }}"><strong>Island Gold<br><span>Signature all-purpose seasoning</span></strong></a>
          <a class="bk-card" href="{{ shop_url }}"><strong>3-Pack<br><span>Stock up and save</span></strong></a>
          <a class="bk-card" href="{{ shop_url }}"><strong>Case Pack<br><span>Best value for loyal customers</span></strong></a>
          <a class="bk-card" href="{{ recipes_url }}"><strong>Recipe Cards<br><span>Pair every bottle with meal inspiration</span></strong></a>
        {% endif %}
      </div>
      <div class="bk-actions" style="justify-content:center;"><a class="bk-btn" href="{{ shop_url }}">Shop Products</a><a class="bk-btn bk-btn--dark" href="{{ chef_services_url }}">Explore Chef Services</a></div>
    </div>
  </div>

  <div class="bk-details">
    <div class="bk-wrap">
      <div class="bk-section-kicker" style="color:var(--green);">Use It On</div>
      <h2 class="bk-section-title" style="color:var(--black);">One Bottle. A Whole Lot Of Plates.</h2>
      <p class="bk-copy" style="max-width:900px;margin:14px auto 0;text-align:center;">Island Gold All-Purpose Seasoning is made for chicken, fish, shrimp, vegetables, rice and peas, soups, eggs, fries, grilled dishes, marinades, wings, roasted potatoes, and everyday cooking.</p>
      <div class="bk-detail-grid">
        <div class="bk-detail"><h3>Big Flavor, Everyday Use</h3><p>Made for meals you already love, from weeknight dinners to weekend cookouts.</p></div>
        <div class="bk-detail"><h3>Built For More Than One Dish</h3><p>Use it across proteins, sides, soups, vegetables, marinades, and grilled favorites.</p></div>
        <div class="bk-detail"><h3>Chef-Driven Flavor</h3><p>Inspired by real kitchen work, family meals, catering, and bold island-style cooking.</p></div>
      </div>
    </div>
  </div>

  <div class="bk-services bk-flag">
    <div class="bk-wrap">
      <div class="bk-section-kicker">Catering & Chef Services</div>
      <h2 class="bk-section-title">Need Briscoe's Kitchen & Spice For An Event?</h2>
      <p class="bk-section-sub">Bring the flavor to your next private event, celebration, corporate gathering, family function, festival, or special occasion. Catering and chef services are custom, personal, and planned around your date, location, guest count, menu needs, and service style.</p>
      <div class="bk-actions" style="justify-content:center;"><a class="bk-btn" href="{{ catering_url }}">Book Catering</a><a class="bk-btn bk-btn--green" href="{{ chef_services_url }}">Explore Chef Services</a><a class="bk-btn bk-btn--dark" href="{{ contact_url }}">Request A Custom Quote</a></div>
    </div>
  </div>

  <div class="bk-details">
    <div class="bk-wrap bk-detail-grid">
      <div class="bk-detail"><h3>Shipping</h3><p>Orders ship from the United States. Domestic shipping is available, with selected international shipping offered where supported. Shipping rates, delivery options, and tracking details are shown during checkout when available.</p></div>
      <div class="bk-detail"><h3>International Orders</h3><p>Selected international shipping is available where supported. International customers are responsible for reviewing delivery timelines and any applicable import duties, taxes, or customs fees required by the destination country.</p></div>
      <div class="bk-detail"><h3>Recipes & Flavor Ideas</h3><p>Get recipes, flavor ideas, kitchen tips, and serving inspiration from Briscoe's Kitchen & Spice so every bottle goes further.</p></div>
    </div>
  </div>

  <div class="bk-community">
    <div class="bk-wrap">
      <div class="bk-section-kicker">The One Pot Family</div>
      <h2 class="bk-section-title">Get The Drops, Recipes, And Flavor First.</h2>
      <p class="bk-section-sub">Join The One Pot Family for restock alerts, new seasoning drops, recipe ideas, chef exclusives, event updates, and special offers from Briscoe's Kitchen & Spice.</p>
      {% form 'customer', class: 'bk-signup' %}
        <input type="hidden" name="contact[tags]" value="newsletter, social-commerce, spice-drop, one-pot-family">
        <input type="email" name="contact[email]" placeholder="your@email.com" required>
        <input type="tel" name="contact[phone]" placeholder="+1 555 000 0000">
        <button class="bk-btn" type="submit">Join The Family</button>
      {% endform %}
      <p class="bk-disclaimer">By signing up, you agree to receive updates from Briscoe's Kitchen & Spice. Message and data rates may apply. Unsubscribe anytime.</p>
    </div>
  </div>

  <div class="bk-partners">
    <div class="bk-wrap">
      <div class="bk-section-kicker" style="color:var(--green);">Brand Partnerships</div>
      <h2 class="bk-section-title" style="color:var(--black);">Partner With Briscoe's Kitchen & Spice</h2>
      <p class="bk-copy" style="max-width:900px;margin:14px auto 0;text-align:center;">Interested in sponsored recipes, product drops, event partnerships, content collaborations, package inserts, retail opportunities, or shoppable media campaigns? Briscoe's Kitchen & Spice partners with select brands, events, creators, food businesses, lifestyle brands, and community-driven campaigns that align with bold flavor and real culture.</p>
      <div class="bk-actions" style="justify-content:center;"><a class="bk-btn" href="{{ partnership_url }}">Partner With Briscoe</a><a class="bk-btn bk-btn--green" href="{{ contact_url }}">Request Partnership Info</a></div>
    </div>
  </div>

  <div class="bk-faq">
    <div class="bk-wrap">
      <div class="bk-section-kicker" style="color:var(--green);">Frequently Asked Questions</div>
      <h2 class="bk-section-title" style="color:var(--black);">Before You Checkout</h2>
      <div class="bk-faq-grid">
        <div class="bk-faq-item"><h3>What Is Island Gold?</h3><p>Island Gold is Briscoe's Kitchen & Spice all-purpose seasoning made for bold, everyday flavor across meats, seafood, vegetables, rice, soups, marinades, and more.</p></div>
        <div class="bk-faq-item"><h3>Where Do Orders Ship From?</h3><p>Orders ship from the United States. Available shipping methods and tracking options are shown during checkout when supported.</p></div>
        <div class="bk-faq-item"><h3>Can I Order Catering Here?</h3><p>This product shop is for direct product orders. For catering, private chef service, custom events, and special requests, use the catering or chef services inquiry options.</p></div>
      </div>
      <div class="bk-actions" style="justify-content:center;"><a class="bk-btn" href="{{ shop_url }}">Shop Island Gold</a><a class="bk-btn bk-btn--green" href="{{ recipes_url }}">Explore Recipes</a><a class="bk-btn bk-btn--dark" href="{{ catering_url }}">Book Catering</a></div>
    </div>
  </div>

  <footer class="bk-footer">
    <div class="bk-wrap bk-footer-grid">
      <div><a class="bk-logo" href="{{ routes.root_url }}"><span class="bk-mark">B</span><span>Briscoe's</span></a><p style="margin-top:16px;">Official product shop for Briscoe's Kitchen & Spice seasonings, bundles, and select flavor drops. For catering, recipes, chef services, custom events, and brand partnerships, explore more with Briscoe's Kitchen & Spice.</p></div>
      <div><h3>Shop</h3><ul><li><a href="{{ shop_url }}">Products</a></li><li><a href="{{ shop_url }}">Island Gold</a></li><li><a href="{{ routes.cart_url }}">Cart</a></li><li><a href="/policies/shipping-policy">Shipping</a></li><li><a href="/policies/refund-policy">Returns</a></li></ul></div>
      <div><h3>Explore</h3><ul><li><a href="{{ recipes_url }}">Recipes</a></li><li><a href="{{ catering_url }}">Catering</a></li><li><a href="{{ chef_services_url }}">Chef Services</a></li><li><a href="{{ partnership_url }}">Brand Partnerships</a></li><li><a href="{{ contact_url }}">Contact</a></li></ul></div>
      <div><h3>Support</h3><ul><li><a href="{{ contact_url }}">Contact</a></li><li><a href="/policies/shipping-policy">Shipping Policy</a></li><li><a href="/policies/refund-policy">Refund Policy</a></li><li><a href="/policies/privacy-policy">Privacy Policy</a></li><li><a href="/policies/terms-of-service">Terms Of Service</a></li></ul></div>
    </div>
    <div class="bk-footer-bottom">&copy; {{ 'now' | date: '%Y' }} Briscoe's Kitchen & Spice. All rights reserved.</div>
  </footer>

  <nav class="bk-sticky" aria-label="Mobile quick actions"><a href="{{ phone_href }}">Call</a><a href="{{ shop_url }}">Shop</a><a href="{{ recipes_url }}">Recipes</a><a href="{{ catering_url }}">Catering</a></nav>
</section>

{% schema %}
{
  "name": "Briscoe Social Shop",
  "tag": "section",
  "class": "section-briscoe-social-shop",
  "settings": [
    { "type": "text", "id": "announcement", "label": "Announcement", "default": "Island Gold is back - shop the official product drop." },
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "Briscoe's Kitchen & Spice" },
    { "type": "text", "id": "hero_kicker", "label": "Hero kicker", "default": "Official Product Shop" },
    { "type": "inline_richtext", "id": "hero_heading", "label": "Hero heading", "default": "Bold Island Flavor. <strong>Shipped From The U.S.</strong>" },
    { "type": "textarea", "id": "hero_text", "label": "Hero text", "default": "Shop the official Briscoe's Kitchen & Spice product drop featuring Island Gold All-Purpose Seasoning, bundles, and select flavor essentials. Bring big flavor to everyday meals, family gatherings, cookouts, events, and weekend plates." },
    { "type": "text", "id": "product_title", "label": "Fallback product title", "default": "Island Gold All-Purpose Seasoning" },
    { "type": "text", "id": "product_subtitle", "label": "Product subtitle", "default": "All-Purpose Seasoning - 5 oz" },
    { "type": "textarea", "id": "product_description", "label": "Fallback product description", "default": "Bold island-inspired flavor made for chicken, fish, shrimp, vegetables, rice and peas, soups, eggs, fries, grilled dishes, marinades, and everyday cooking." },
    { "type": "text", "id": "review_count", "label": "Review label", "default": "Fan-favorite drop" },
    { "type": "text", "id": "single_price", "label": "Single price", "default": "$9.99" },
    { "type": "text", "id": "three_pack_price", "label": "3-pack price", "default": "$27.99" },
    { "type": "text", "id": "case_price", "label": "Case price", "default": "$99.99" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero product image" },
    { "type": "image_picker", "id": "product_image", "label": "Fallback product detail image" },
    { "type": "url", "id": "shop_url", "label": "Shop URL" },
    { "type": "url", "id": "full_site_url", "label": "Explore Briscoe URL" },
    { "type": "url", "id": "catering_url", "label": "Catering URL" },
    { "type": "url", "id": "recipes_url", "label": "Recipes URL" },
    { "type": "url", "id": "chef_services_url", "label": "Chef services URL" },
    { "type": "url", "id": "partnership_url", "label": "Brand partnerships URL" },
    { "type": "url", "id": "contact_url", "label": "Contact URL" },
    { "type": "text", "id": "phone", "label": "Phone", "default": "+1 202 555 0100" }
  ],
  "blocks": [
    {
      "type": "product_tile",
      "name": "Product tile",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Island Gold" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Signature all-purpose seasoning" },
        { "type": "url", "id": "url", "label": "URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Briscoe Social Shop",
      "blocks": [
        { "type": "product_tile" },
        { "type": "product_tile", "settings": { "title": "3-Pack", "subtitle": "Stock up and save" } },
        { "type": "product_tile", "settings": { "title": "Case Pack", "subtitle": "Best value for loyal customers" } },
        { "type": "product_tile", "settings": { "title": "Recipe Cards", "subtitle": "Pair every bottle with meal inspiration" } }
      ]
    }
  ]
}
{% endschema %}
