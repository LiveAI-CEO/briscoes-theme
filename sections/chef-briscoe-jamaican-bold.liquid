{% liquid
  assign shop_url = section.settings.shop_url | default: '/collections/all'
  assign full_site_url = section.settings.full_site_url | default: 'https://briscoeskitchen.com'
  assign catering_url = section.settings.catering_url | default: full_site_url
  assign contact_url = section.settings.contact_url | default: full_site_url
  assign recipes_url = section.settings.recipes_url | default: full_site_url
  assign phone_href = section.settings.phone | remove: ' ' | remove: '(' | remove: ')' | remove: '-' | prepend: 'tel:'
  assign display_title = section.settings.product_title
  assign display_price = section.settings.single_price
  assign display_description = section.settings.product_description
  assign hero_alt = section.settings.hero_image.alt | default: display_title
  assign product_alt = section.settings.product_image.alt | default: display_title
  if product
    assign display_title = product.title
    assign display_price = product.price | money
    assign display_description = product.description | strip_html | truncate: 180
  endif
%}

<section id="briscoe-social-shop-{{ section.id }}" class="bk-mirror">
  <style>
    #shopify-section-{{ section.id }} {
      --black: #050505;
      --green: #008f39;
      --gold: #ffcb05;
      --gold-deep: #d89b00;
      --cream: #fff7df;
      --white: #ffffff;
      --ink: #111111;
      --line: #050505;
      color: var(--ink);
      font-family: Impact, Haettenschweiler, "Arial Narrow Bold", Arial, sans-serif;
      letter-spacing: 0;
    }

    #shopify-section-{{ section.id }} * {
      box-sizing: border-box;
    }

    #shopify-section-{{ section.id }} .bk-mirror {
      background: var(--cream);
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .bk-wrap {
      width: min(1180px, calc(100% - 32px));
      margin: 0 auto;
    }

    #shopify-section-{{ section.id }} h1,
    #shopify-section-{{ section.id }} h2,
    #shopify-section-{{ section.id }} h3,
    #shopify-section-{{ section.id }} p {
      margin: 0;
    }

    #shopify-section-{{ section.id }} .bk-top {
      background: var(--black);
      color: var(--gold);
      text-align: center;
      padding: 10px 16px;
      border-bottom: 4px solid var(--line);
      font-size: clamp(18px, 2.4vw, 32px);
      line-height: .95;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-nav {
      background: linear-gradient(180deg, #00a746, var(--green));
      border-bottom: 4px solid var(--line);
    }

    #shopify-section-{{ section.id }} .bk-nav-inner {
      min-height: 62px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .bk-logo,
    #shopify-section-{{ section.id }} .bk-nav a {
      color: var(--gold);
      text-decoration: none;
      text-transform: uppercase;
      text-shadow: 2px 2px 0 rgba(0,0,0,.5);
    }

    #shopify-section-{{ section.id }} .bk-logo {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-size: clamp(26px, 3.2vw, 42px);
      line-height: .9;
      -webkit-text-stroke: 1px var(--line);
    }

    #shopify-section-{{ section.id }} .bk-mark {
      width: 46px;
      height: 46px;
      display: grid;
      place-items: center;
      border: 3px solid var(--gold);
      border-radius: 50%;
      background: var(--black);
      color: var(--gold);
      font-size: 24px;
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .bk-links {
      display: flex;
      align-items: center;
      gap: clamp(14px, 2vw, 28px);
      font-size: clamp(17px, 1.7vw, 23px);
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .bk-cart {
      min-width: 74px;
      min-height: 44px;
      display: grid;
      place-items: center;
      border: 3px solid var(--line);
      border-radius: 999px;
      background: var(--gold);
      color: var(--black) !important;
      text-shadow: none !important;
      box-shadow: 0 4px 0 rgba(0,0,0,.55);
    }

    #shopify-section-{{ section.id }} .bk-flag {
      background:
        linear-gradient(34deg, transparent 0 43%, var(--gold) 43% 48%, transparent 48% 52%, var(--gold) 52% 57%, transparent 57%),
        linear-gradient(146deg, var(--green) 0 48%, var(--black) 48% 52%, var(--green) 52% 100%);
    }

    #shopify-section-{{ section.id }} .bk-hero {
      min-height: 560px;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(340px, .86fr);
      border-bottom: 6px solid var(--line);
      color: var(--white);
      background-color: var(--black);
    }

    #shopify-section-{{ section.id }} .bk-hero-copy {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: clamp(34px, 6vw, 74px);
      background: linear-gradient(90deg, var(--black) 0 82%, rgba(0,0,0,.15));
      position: relative;
      z-index: 1;
    }

    #shopify-section-{{ section.id }} .bk-eyebrow,
    #shopify-section-{{ section.id }} .bk-section-kicker {
      color: var(--gold);
      font-size: clamp(18px, 2vw, 28px);
      line-height: 1;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-title {
      max-width: 780px;
      margin-top: 12px;
      color: var(--white);
      font-size: clamp(58px, 9vw, 132px);
      line-height: .78;
      text-transform: uppercase;
      text-shadow: 0 6px 0 rgba(0,0,0,.7), 0 16px 30px rgba(0,0,0,.6);
    }

    #shopify-section-{{ section.id }} .bk-title strong,
    #shopify-section-{{ section.id }} .bk-script {
      display: block;
      color: var(--gold);
      font-family: Georgia, "Times New Roman", serif;
      font-style: italic;
      font-weight: 900;
      line-height: .9;
      text-transform: none;
    }

    #shopify-section-{{ section.id }} .bk-lead {
      max-width: 660px;
      margin-top: 18px;
      color: var(--gold);
      font-family: Arial, sans-serif;
      font-size: clamp(19px, 2vw, 28px);
      line-height: 1.18;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .bk-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      margin-top: 28px;
    }

    #shopify-section-{{ section.id }} .bk-btn,
    #shopify-section-{{ section.id }} button.bk-btn {
      min-height: 56px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 13px 24px;
      border: 3px solid var(--line);
      border-radius: 8px;
      background: linear-gradient(180deg, #ffe15a, var(--gold));
      color: var(--black);
      box-shadow: 0 5px 0 var(--line);
      font: inherit;
      font-size: clamp(18px, 1.8vw, 25px);
      line-height: .95;
      text-decoration: none;
      text-transform: uppercase;
      cursor: pointer;
    }

    #shopify-section-{{ section.id }} .bk-btn--green {
      background: linear-gradient(180deg, #05aa4d, var(--green));
      color: var(--gold);
    }

    #shopify-section-{{ section.id }} .bk-btn--dark {
      background: var(--black);
      color: var(--gold);
    }

    #shopify-section-{{ section.id }} .bk-hero-art {
      min-height: 560px;
      display: grid;
      place-items: center;
      padding: 44px 24px;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .bk-product-stack {
      position: relative;
      width: min(420px, 78vw);
      aspect-ratio: 1 / 1.08;
      display: grid;
      place-items: center;
    }

    #shopify-section-{{ section.id }} .bk-spice-swoosh {
      position: absolute;
      width: 118%;
      height: 42%;
      border-radius: 50%;
      background:
        radial-gradient(circle, rgba(255,255,255,.9) 0 1px, transparent 2px) 0 0 / 22px 22px,
        linear-gradient(90deg, transparent, #f16d12 22%, var(--gold) 54%, transparent);
      filter: drop-shadow(0 0 12px rgba(255,203,5,.68));
      transform: rotate(-18deg);
    }

    #shopify-section-{{ section.id }} .bk-bottle {
      position: relative;
      width: min(190px, 42vw);
      height: 360px;
      border: 4px solid var(--line);
      border-radius: 20px 20px 32px 32px;
      background:
        linear-gradient(90deg, rgba(255,255,255,.36), transparent 20% 70%, rgba(0,0,0,.22)),
        repeating-linear-gradient(0deg, #c86b18 0 6px, #f5a82a 6px 12px);
      box-shadow: 22px 30px 0 rgba(0,0,0,.38), 0 0 38px rgba(255,203,5,.36);
      overflow: hidden;
      transform: rotate(12deg);
    }

    #shopify-section-{{ section.id }} .bk-bottle::before {
      content: "";
      position: absolute;
      left: 30px;
      right: 30px;
      top: -35px;
      height: 78px;
      border: 4px solid var(--line);
      border-radius: 16px 16px 8px 8px;
      background: #141414;
    }

    #shopify-section-{{ section.id }} .bk-label {
      position: absolute;
      left: 14px;
      right: 14px;
      top: 106px;
      min-height: 150px;
      display: grid;
      place-items: center;
      padding: 12px 8px;
      border: 4px solid var(--line);
      background:
        linear-gradient(34deg, transparent 0 43%, var(--gold) 43% 49%, transparent 49% 51%, var(--gold) 51% 57%, transparent 57%),
        linear-gradient(146deg, var(--green) 0 48%, var(--black) 48% 52%, var(--green) 52% 100%);
      color: var(--gold);
      text-align: center;
      text-transform: uppercase;
      font-size: 36px;
      line-height: .82;
      text-shadow: 2px 2px 0 var(--black);
    }

    #shopify-section-{{ section.id }} .bk-label small {
      display: block;
      margin-top: 7px;
      color: var(--white);
      font-size: 13px;
    }

    #shopify-section-{{ section.id }} .bk-marquee {
      background: var(--gold);
      color: var(--black);
      border-bottom: 6px solid var(--line);
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .bk-marquee-track {
      display: flex;
      width: max-content;
      animation: bkMove-{{ section.id }} 24s linear infinite;
      white-space: nowrap;
    }

    #shopify-section-{{ section.id }} .bk-marquee span {
      display: inline-flex;
      align-items: center;
      gap: 20px;
      padding: 14px 22px;
      font-size: clamp(24px, 3vw, 42px);
      line-height: 1;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-marquee span::after {
      content: "";
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: var(--black);
    }

    @keyframes bkMove-{{ section.id }} {
      to { transform: translateX(-50%); }
    }

    #shopify-section-{{ section.id }} .bk-product {
      padding: 34px 0;
      background: var(--cream);
    }

    #shopify-section-{{ section.id }} .bk-product-grid {
      display: grid;
      grid-template-columns: minmax(320px, .95fr) minmax(320px, 1fr);
      gap: 36px;
      align-items: start;
    }

    #shopify-section-{{ section.id }} .bk-product-media {
      min-height: 430px;
      display: grid;
      place-items: center;
      border: 4px solid var(--line);
      border-radius: 10px;
      background:
        radial-gradient(circle at 30% 35%, rgba(255,203,5,.4), transparent 24%),
        linear-gradient(34deg, transparent 0 43%, var(--gold) 43% 48%, transparent 48% 52%, var(--gold) 52% 57%, transparent 57%),
        #f5e6be;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .bk-product-media img,
    #shopify-section-{{ section.id }} .bk-chef-photo img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    #shopify-section-{{ section.id }} .bk-thumbs {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 10px;
      margin-top: 12px;
    }

    #shopify-section-{{ section.id }} .bk-thumb {
      aspect-ratio: 1 / .72;
      border: 4px solid var(--line);
      border-radius: 10px;
      background:
        linear-gradient(34deg, transparent 0 43%, var(--gold) 43% 48%, transparent 48% 52%, var(--gold) 52% 57%, transparent 57%),
        linear-gradient(146deg, var(--green) 0 48%, var(--black) 48% 52%, var(--green) 52% 100%);
      outline: 4px solid var(--green);
      outline-offset: -8px;
    }

    #shopify-section-{{ section.id }} .bk-breadcrumb {
      color: var(--green);
      font-size: 18px;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-product-title {
      margin-top: 4px;
      color: var(--black);
      font-size: clamp(54px, 6vw, 86px);
      line-height: .82;
      text-transform: uppercase;
      text-shadow: 0 3px 0 rgba(255,203,5,.55);
    }

    #shopify-section-{{ section.id }} .bk-underline {
      display: block;
      width: min(520px, 100%);
      height: 10px;
      margin: 8px 0 6px;
      border-radius: 999px;
      background: var(--gold);
    }

    #shopify-section-{{ section.id }} .bk-product-sub {
      color: var(--green);
      font-family: Georgia, "Times New Roman", serif;
      font-style: italic;
      font-size: clamp(27px, 3vw, 42px);
      line-height: 1;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .bk-stars {
      margin-top: 10px;
      color: var(--gold-deep);
      font-family: Arial, sans-serif;
      font-size: 19px;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .bk-stars span {
      color: var(--black);
      font-size: 15px;
    }

    #shopify-section-{{ section.id }} .bk-price {
      margin-top: 8px;
      color: var(--black);
      font-size: clamp(42px, 5vw, 62px);
      line-height: .9;
    }

    #shopify-section-{{ section.id }} .bk-desc,
    #shopify-section-{{ section.id }} .bk-policy-note,
    #shopify-section-{{ section.id }} .bk-routing p {
      color: var(--black);
      font-family: Arial, sans-serif;
      font-size: 18px;
      line-height: 1.28;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .bk-pack-label {
      display: block;
      margin-top: 18px;
      color: var(--black);
      font-size: 20px;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-packs {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin-top: 8px;
    }

    #shopify-section-{{ section.id }} .bk-pack {
      min-height: 58px;
      display: grid;
      place-items: center;
      padding: 8px 12px;
      border: 4px solid var(--line);
      border-radius: 999px;
      background: var(--cream);
      color: var(--black);
      text-align: center;
      font-size: 20px;
      line-height: .92;
      box-shadow: 0 4px 0 rgba(0,0,0,.2);
      text-decoration: none;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-pack--green {
      background: var(--green);
      color: var(--white);
    }

    #shopify-section-{{ section.id }} .bk-pack--gold {
      background: var(--gold);
    }

    #shopify-section-{{ section.id }} .bk-buy-row {
      display: grid;
      grid-template-columns: 120px minmax(0, 1fr);
      gap: 12px;
      margin-top: 16px;
    }

    #shopify-section-{{ section.id }} .bk-qty {
      min-height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-around;
      border: 4px solid var(--line);
      border-radius: 8px;
      background: var(--cream);
      color: var(--black);
      font-size: 30px;
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .bk-cart-btn {
      min-height: 58px;
      display: grid;
      place-items: center;
      border: 4px solid var(--line);
      border-radius: 8px;
      background: var(--green);
      color: var(--gold);
      box-shadow: 0 5px 0 var(--line);
      font: inherit;
      font-size: clamp(22px, 2.5vw, 32px);
      line-height: .95;
      text-transform: uppercase;
      text-decoration: none;
    }

    #shopify-section-{{ section.id }} .bk-trust {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-top: 18px;
    }

    #shopify-section-{{ section.id }} .bk-trust-item {
      display: grid;
      grid-template-columns: 42px 1fr;
      gap: 8px;
      align-items: center;
      color: var(--black);
      font-family: Arial, sans-serif;
      font-size: 13px;
      font-weight: 900;
      line-height: 1.04;
    }

    #shopify-section-{{ section.id }} .bk-icon {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border: 3px solid var(--gold);
      border-radius: 50%;
      background: var(--black);
      color: var(--gold);
      font-family: Arial, sans-serif;
      font-size: 12px;
    }

    #shopify-section-{{ section.id }} .bk-mirror-products,
    #shopify-section-{{ section.id }} .bk-routing,
    #shopify-section-{{ section.id }} .bk-product-details {
      padding: 58px 0;
      border-top: 6px solid var(--line);
    }

    #shopify-section-{{ section.id }} .bk-mirror-products {
      background: var(--green);
      color: var(--white);
      text-align: center;
    }

    #shopify-section-{{ section.id }} .bk-section-title {
      margin-top: 8px;
      color: var(--white);
      font-size: clamp(44px, 6vw, 82px);
      line-height: .88;
      text-transform: uppercase;
      text-shadow: 0 5px 0 rgba(0,0,0,.35);
    }

    #shopify-section-{{ section.id }} .bk-section-sub {
      margin: 12px auto 0;
      max-width: 820px;
      color: var(--gold);
      font-family: Georgia, "Times New Roman", serif;
      font-style: italic;
      font-size: clamp(23px, 3vw, 38px);
      font-weight: 900;
      line-height: 1.08;
    }

    #shopify-section-{{ section.id }} .bk-card-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-top: 28px;
    }

    #shopify-section-{{ section.id }} .bk-card {
      min-height: 210px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      border: 5px solid var(--gold-deep);
      background:
        radial-gradient(circle at 42% 28%, rgba(255,255,255,.35), transparent 23%),
        linear-gradient(135deg, #6d3b16, #f7b73d 48%, #1d5c2a);
      box-shadow: 0 8px 0 rgba(0,0,0,.32);
      color: var(--gold);
      text-decoration: none;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .bk-card strong {
      display: block;
      padding: 12px 8px;
      background: var(--black);
      font-size: clamp(22px, 2.3vw, 34px);
      line-height: .92;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-card span {
      color: var(--white);
      font-family: Arial, sans-serif;
      font-size: 14px;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .bk-routing {
      background:
        linear-gradient(34deg, transparent 0 43%, rgba(255,203,5,.78) 43% 47%, transparent 47% 53%, rgba(255,203,5,.78) 53% 57%, transparent 57%),
        var(--black);
      color: var(--white);
      text-align: center;
    }

    #shopify-section-{{ section.id }} .bk-routing h2 {
      color: var(--white);
      font-size: clamp(44px, 6vw, 86px);
      line-height: .9;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-routing p {
      max-width: 820px;
      margin: 14px auto 0;
      color: var(--white);
      font-size: clamp(18px, 2vw, 24px);
    }

    #shopify-section-{{ section.id }} .bk-product-details {
      background: var(--cream);
    }

    #shopify-section-{{ section.id }} .bk-detail-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }

    #shopify-section-{{ section.id }} details {
      border: 4px solid var(--line);
      border-radius: 8px;
      background: var(--cream);
      box-shadow: inset 0 0 0 3px var(--green);
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} summary {
      cursor: pointer;
      padding: 14px 18px;
      color: var(--green);
      font-size: clamp(22px, 2.5vw, 32px);
      line-height: 1;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} details p {
      padding: 16px 18px 22px;
      border-top: 2px solid rgba(0,143,57,.28);
      color: var(--black);
      font-family: Arial, sans-serif;
      font-size: 16px;
      line-height: 1.28;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .bk-capture {
      padding: 68px 0 54px;
      background: var(--black);
      color: var(--white);
      text-align: center;
      border-top: 6px solid var(--line);
    }

    #shopify-section-{{ section.id }} .bk-capture h2 {
      color: var(--white);
      font-size: clamp(44px, 6vw, 84px);
      line-height: .9;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-capture p {
      margin-top: 10px;
      color: var(--gold);
      font-family: Georgia, "Times New Roman", serif;
      font-style: italic;
      font-size: clamp(24px, 3vw, 38px);
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .bk-signup {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, .72fr) auto;
      gap: 12px;
      width: min(920px, 100%);
      margin: 28px auto 0;
    }

    #shopify-section-{{ section.id }} .bk-signup input {
      min-height: 62px;
      border: 4px solid var(--gold);
      border-radius: 8px;
      padding: 12px 18px;
      color: var(--black);
      background: var(--white);
      font: 900 22px/1 Arial, sans-serif;
    }

    #shopify-section-{{ section.id }} .bk-footer {
      padding: 42px 0 0;
      background: linear-gradient(180deg, #00a746, var(--green));
      color: var(--white);
      border-top: 6px solid var(--line);
    }

    #shopify-section-{{ section.id }} .bk-footer-grid {
      display: grid;
      grid-template-columns: 1.2fr repeat(3, 1fr);
      gap: 32px;
      padding-bottom: 40px;
    }

    #shopify-section-{{ section.id }} .bk-footer h3 {
      color: var(--gold);
      font-size: 32px;
      line-height: 1;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .bk-footer p,
    #shopify-section-{{ section.id }} .bk-footer a {
      color: var(--white);
      font-family: Arial, sans-serif;
      font-size: 17px;
      line-height: 1.35;
      font-weight: 900;
      text-decoration: none;
    }

    #shopify-section-{{ section.id }} .bk-footer ul {
      display: grid;
      gap: 10px;
      list-style: none;
      margin: 14px 0 0;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .bk-footer-bottom {
      padding: 10px 16px;
      border-top: 6px solid var(--black);
      background: var(--gold);
      color: var(--black);
      text-align: center;
      font-size: 20px;
      line-height: 1;
    }

    #shopify-section-{{ section.id }} .bk-sticky {
      display: none;
    }

    @media (max-width: 990px) {
      #shopify-section-{{ section.id }} .bk-hero,
      #shopify-section-{{ section.id }} .bk-product-grid,
      #shopify-section-{{ section.id }} .bk-detail-grid,
      #shopify-section-{{ section.id }} .bk-footer-grid {
        grid-template-columns: 1fr;
      }

      #shopify-section-{{ section.id }} .bk-card-grid,
      #shopify-section-{{ section.id }} .bk-trust {
        grid-template-columns: repeat(2, 1fr);
      }

      #shopify-section-{{ section.id }} .bk-links {
        display: none;
      }
    }

    @media (max-width: 640px) {
      #shopify-section-{{ section.id }} .bk-wrap {
        width: min(100% - 24px, 1180px);
      }

      #shopify-section-{{ section.id }} .bk-hero,
      #shopify-section-{{ section.id }} .bk-hero-art {
        min-height: auto;
      }

      #shopify-section-{{ section.id }} .bk-hero-copy {
        padding: 34px 18px;
      }

      #shopify-section-{{ section.id }} .bk-title {
        font-size: clamp(52px, 17vw, 74px);
      }

      #shopify-section-{{ section.id }} .bk-packs,
      #shopify-section-{{ section.id }} .bk-buy-row,
      #shopify-section-{{ section.id }} .bk-card-grid,
      #shopify-section-{{ section.id }} .bk-trust,
      #shopify-section-{{ section.id }} .bk-signup,
      #shopify-section-{{ section.id }} .bk-thumbs {
        grid-template-columns: 1fr;
      }

      #shopify-section-{{ section.id }} .bk-actions,
      #shopify-section-{{ section.id }} .bk-btn,
      #shopify-section-{{ section.id }} .bk-cart-btn {
        width: 100%;
      }

      #shopify-section-{{ section.id }} .bk-product-media {
        min-height: 320px;
      }

      #shopify-section-{{ section.id }} .bk-sticky {
        position: fixed;
        left: 8px;
        right: 8px;
        bottom: 8px;
        z-index: 20;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6px;
        padding: 7px;
        border: 2px solid var(--gold);
        border-radius: 8px;
        background: rgba(0,0,0,.9);
      }

      #shopify-section-{{ section.id }} .bk-sticky a {
        min-height: 42px;
        display: grid;
        place-items: center;
        border-radius: 6px;
        background: var(--gold);
        color: var(--black);
        font-size: 12px;
        text-decoration: none;
        text-transform: uppercase;
      }

      #shopify-section-{{ section.id }} .bk-sticky a:nth-child(2) {
        background: var(--green);
        color: var(--white);
      }
    }
  </style>

  <div class="bk-top">{{ section.settings.announcement }}</div>

  <nav class="bk-nav" aria-label="Main navigation">
    <div class="bk-wrap bk-nav-inner">
      <a class="bk-logo" href="{{ routes.root_url }}"><span class="bk-mark">B</span><span>{{ section.settings.brand_name }}</span></a>
      <div class="bk-links">
        <a href="{{ shop_url }}">Shop</a>
        <a href="{{ full_site_url }}">Full Website</a>
        <a href="{{ catering_url }}">Catering</a>
        <a href="{{ contact_url }}">Contact</a>
      </div>
      <a class="bk-cart" href="{{ routes.cart_url }}">Cart</a>
    </div>
  </nav>

  <div class="bk-hero bk-flag">
    <div class="bk-hero-copy">
      <p class="bk-eyebrow">Official Product Shop</p>
      <h1 class="bk-title">{{ section.settings.hero_heading }}</h1>
      <p class="bk-lead">{{ section.settings.hero_text }}</p>
      <div class="bk-actions">
        <a class="bk-btn" href="{{ shop_url }}">Shop Products</a>
        <a class="bk-btn bk-btn--green" href="{{ full_site_url }}">Visit Full Site</a>
        <a class="bk-btn bk-btn--dark" href="{{ catering_url }}">Book Catering</a>
      </div>
    </div>

    <div class="bk-hero-art">
      {% if section.settings.hero_image != blank %}
        <div class="bk-product-stack">
          <span class="bk-spice-swoosh"></span>
          {{ section.settings.hero_image | image_url: width: 900 | image_tag: loading: 'eager', alt: hero_alt }}
        </div>
      {% else %}
        <div class="bk-product-stack" aria-label="{{ display_title }}">
          <span class="bk-spice-swoosh"></span>
          <div class="bk-bottle">
            <div class="bk-label">Island<br>Gold<small>Briscoe's Kitchen & Spice</small></div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="bk-marquee" aria-hidden="true">
    <div class="bk-marquee-track">
      {% for i in (1..2) %}
        <span>Shopify Product Checkout</span>
        <span>YouTube Store Ready</span>
        <span>Google Shopping Ready</span>
        <span>Instagram Shop Ready</span>
        <span>Full Services On Main Site</span>
      {% endfor %}
    </div>
  </div>

  <div class="bk-product">
    <div class="bk-wrap bk-product-grid">
      <div>
        <div class="bk-product-media">
          {% if product and product.featured_image != blank %}
            {{ product.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: product.title }}
          {% elsif section.settings.product_image != blank %}
            {{ section.settings.product_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: product_alt }}
          {% else %}
            <div class="bk-product-stack">
              <span class="bk-spice-swoosh"></span>
              <div class="bk-bottle">
                <div class="bk-label">Island<br>Gold<small>All Purpose Seasoning</small></div>
              </div>
            </div>
          {% endif %}
        </div>
        <div class="bk-thumbs" aria-label="Product preview thumbnails">
          <div class="bk-thumb"></div>
          <div class="bk-thumb"></div>
          <div class="bk-thumb"></div>
          <div class="bk-thumb"></div>
          <div class="bk-thumb"></div>
        </div>
      </div>

      <div>
        <div class="bk-breadcrumb">Shop / Social Commerce Products</div>
        <h2 class="bk-product-title">{{ display_title }}</h2>
        <span class="bk-underline"></span>
        <div class="bk-product-sub">{{ section.settings.product_subtitle }}</div>
        <div class="bk-stars">&#9733;&#9733;&#9733;&#9733;&#9733; <span>({{ section.settings.review_count }} reviews)</span></div>
        <div class="bk-price">{{ display_price }}</div>
        <p class="bk-desc">{{ display_description }}</p>

        <span class="bk-pack-label">Choose your pack</span>
        <div class="bk-packs">
          <a class="bk-pack" href="{{ shop_url }}"><strong>Single</strong><span>{{ section.settings.single_price }}</span></a>
          <a class="bk-pack bk-pack--green" href="{{ shop_url }}"><strong>3-Pack</strong><span>{{ section.settings.three_pack_price }}</span></a>
          <a class="bk-pack bk-pack--gold" href="{{ shop_url }}"><strong>Case Pack</strong><span>{{ section.settings.case_price }}</span></a>
        </div>

        {% if product and product.available %}
          {% form 'product', product %}
            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
            <div class="bk-buy-row">
              <div class="bk-qty" aria-label="Quantity"><span>-</span><strong>1</strong><span>+</span></div>
              <button class="bk-cart-btn" type="submit">Add To Cart - {{ product.selected_or_first_available_variant.price | money }}</button>
            </div>
          {% endform %}
        {% else %}
          <div class="bk-buy-row">
            <div class="bk-qty" aria-label="Quantity"><span>-</span><strong>1</strong><span>+</span></div>
            <a class="bk-cart-btn" href="{{ shop_url }}">Shop Products</a>
          </div>
        {% endif %}

        <p class="bk-policy-note" style="margin-top:14px;color:var(--green);">Ships from the United States. Selected international shipping available where configured.</p>

        <div class="bk-trust">
          <div class="bk-trust-item"><span class="bk-icon">SKU</span><span>Clean SKU catalog</span></div>
          <div class="bk-trust-item"><span class="bk-icon">Ship</span><span>Shippo fulfillment</span></div>
          <div class="bk-trust-item"><span class="bk-icon">Meta</span><span>Social shop eligible</span></div>
          <div class="bk-trust-item"><span class="bk-icon">Lock</span><span>Secure checkout</span></div>
        </div>
      </div>
    </div>
  </div>

  <div class="bk-mirror-products">
    <div class="bk-wrap">
      <div class="bk-section-kicker">Curated Product Catalog</div>
      <h2 class="bk-section-title">Only The Products Built For Social Shops.</h2>
      <p class="bk-section-sub">Seasonings, bundles, merch, recipe cards, and productized offers belong here. Catering and custom chef service stay on the full site.</p>
      <div class="bk-card-grid">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <a class="bk-card" href="{{ block.settings.url | default: shop_url }}" {{ block.shopify_attributes }}>
              <strong>{{ block.settings.title }}<br><span>{{ block.settings.subtitle }}</span></strong>
            </a>
          {% endfor %}
        {% else %}
          <a class="bk-card" href="{{ shop_url }}"><strong>Island Gold<br><span>All-purpose seasoning</span></strong></a>
          <a class="bk-card" href="{{ shop_url }}"><strong>3-Pack<br><span>AOV booster</span></strong></a>
          <a class="bk-card" href="{{ shop_url }}"><strong>Case Pack<br><span>Best value</span></strong></a>
          <a class="bk-card" href="{{ shop_url }}"><strong>Recipe Cards<br><span>Product add-on</span></strong></a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="bk-routing">
    <div class="bk-wrap">
      <h2>Need Catering, Private Chef, Or VIP Access?</h2>
      <p>Those experiences are custom and relationship-driven. Start them on the full Briscoe's Kitchen & Spice site so the team can quote, plan, follow up, and support you properly.</p>
      <div class="bk-actions" style="justify-content:center;">
        <a class="bk-btn" href="{{ full_site_url }}">Visit Full Site</a>
        <a class="bk-btn bk-btn--green" href="{{ catering_url }}">Book Catering</a>
        <a class="bk-btn bk-btn--dark" href="{{ recipes_url }}">Recipes & Flavor Hub</a>
      </div>
    </div>
  </div>

  <div class="bk-product-details">
    <div class="bk-wrap bk-detail-grid">
      <details open>
        <summary>Use It On</summary>
        <p>Chicken, fish, shrimp, vegetables, rice and peas, soups, eggs, fries, grilled dishes, marinades, and everyday cooking.</p>
      </details>
      <details>
        <summary>Shipping</summary>
        <p>Ships from the United States. Confirm SKU, product value, weight, country of origin, package template, and international eligibility before enabling each market.</p>
      </details>
      <details>
        <summary>Full Experience</summary>
        <p>For catering, recipes, chef services, VIP access, community, lead magnets, and custom quotes, continue to the full Briscoe's Kitchen & Spice site.</p>
      </details>
    </div>
  </div>

  <div class="bk-capture">
    <div class="bk-wrap">
      <h2>Get The Next Flavor Drop.</h2>
      <p>Restock alerts, recipes, and Chef Briscoe exclusives.</p>
      {% form 'customer', class: 'bk-signup' %}
        <input type="hidden" name="contact[tags]" value="newsletter, social-commerce, spice-drop">
        <input type="email" name="contact[email]" placeholder="your@email.com" required>
        <input type="tel" name="contact[phone]" placeholder="+1 555 000 0000">
        <button class="bk-btn" type="submit">Join The Family</button>
      {% endform %}
    </div>
  </div>

  <footer class="bk-footer">
    <div class="bk-wrap bk-footer-grid">
      <div>
        <a class="bk-logo" href="{{ routes.root_url }}"><span class="bk-mark">B</span><span>Briscoe's</span></a>
        <p style="margin-top:16px;">Official product shop for social checkout. Full services, recipes, and custom experiences live on the main website.</p>
      </div>
      <div>
        <h3>Shop</h3>
        <ul>
          <li><a href="{{ shop_url }}">Products</a></li>
          <li><a href="{{ routes.cart_url }}">Cart</a></li>
          <li><a href="/policies/shipping-policy">Shipping</a></li>
          <li><a href="/policies/refund-policy">Returns</a></li>
        </ul>
      </div>
      <div>
        <h3>Full Site</h3>
        <ul>
          <li><a href="{{ full_site_url }}">Main Website</a></li>
          <li><a href="{{ catering_url }}">Catering</a></li>
          <li><a href="{{ recipes_url }}">Recipes</a></li>
          <li><a href="{{ contact_url }}">Contact</a></li>
        </ul>
      </div>
      <div>
        <h3>Policies</h3>
        <ul>
          <li><a href="/policies/privacy-policy">Privacy</a></li>
          <li><a href="/policies/terms-of-service">Terms</a></li>
          <li><a href="/policies/refund-policy">Refunds</a></li>
          <li><a href="/policies/shipping-policy">Shipping</a></li>
        </ul>
      </div>
    </div>
    <div class="bk-footer-bottom">&copy; {{ 'now' | date: '%Y' }} Briscoe's Kitchen & Spice - Product shop powered for social commerce</div>
  </footer>

  <nav class="bk-sticky" aria-label="Mobile quick actions">
    <a href="{{ phone_href }}">Call</a>
    <a href="{{ shop_url }}">Shop</a>
    <a href="{{ full_site_url }}">Full Site</a>
    <a href="{{ catering_url }}">Catering</a>
  </nav>
</section>

{% schema %}
{
  "name": "Briscoe Social Shop",
  "tag": "section",
  "class": "section-briscoe-social-shop",
  "settings": [
    {
      "type": "text",
      "id": "announcement",
      "label": "Announcement",
      "default": "Island Gold is back - shop the official product drop"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "Briscoe's Kitchen & Spice"
    },
    {
      "type": "inline_richtext",
      "id": "hero_heading",
      "label": "Hero heading",
      "default": "Bold. Flavorful. <strong>Island Spice.</strong>"
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Hero text",
      "default": "Island-inspired flavor shipped from the U.S. Shop seasonings here, or visit the full site for catering, recipes, VIP chef access, and custom event service."
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Fallback product title",
      "default": "Island Gold All-Purpose Seasoning"
    },
    {
      "type": "text",
      "id": "product_subtitle",
      "label": "Product subtitle",
      "default": "All-Purpose Seasoning - 5 oz"
    },
    {
      "type": "textarea",
      "id": "product_description",
      "label": "Fallback product description",
      "default": "Bold island-inspired flavor for meats, seafood, vegetables, rice, soups, marinades, and everyday cooking."
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count",
      "default": "247"
    },
    {
      "type": "text",
      "id": "single_price",
      "label": "Single price",
      "default": "$9.99"
    },
    {
      "type": "text",
      "id": "three_pack_price",
      "label": "3-pack price",
      "default": "$27.99"
    },
    {
      "type": "text",
      "id": "case_price",
      "label": "Case price",
      "default": "$99.99"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero product image"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Fallback product detail image"
    },
    {
      "type": "url",
      "id": "shop_url",
      "label": "Shop URL"
    },
    {
      "type": "url",
      "id": "full_site_url",
      "label": "Full GHL site URL"
    },
    {
      "type": "url",
      "id": "catering_url",
      "label": "Catering URL"
    },
    {
      "type": "url",
      "id": "recipes_url",
      "label": "Recipes URL"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact URL"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone",
      "default": "+1 202 555 0100"
    }
  ],
  "blocks": [
    {
      "type": "product_tile",
      "name": "Product tile",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Island Gold"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "All-purpose seasoning"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Briscoe Social Shop",
      "blocks": [
        {
          "type": "product_tile"
        },
        {
          "type": "product_tile",
          "settings": {
            "title": "3-Pack",
            "subtitle": "Bundle offer"
          }
        },
        {
          "type": "product_tile",
          "settings": {
            "title": "Case Pack",
            "subtitle": "Best value"
          }
        },
        {
          "type": "product_tile",
          "settings": {
            "title": "Recipe Cards",
            "subtitle": "Product add-on"
          }
        }
      ]
    }
  ]
}
{% endschema %}
