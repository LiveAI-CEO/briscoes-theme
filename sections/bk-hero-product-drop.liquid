<section class="bk-section bk-hero-product-drop bk-flag-bg">
  <div class="bk-wrap bk-hero-grid">
    <div class="bk-hero-copy">
      <p class="bk-kicker">{{ section.settings.kicker }}</p>
      <h1 class="bk-hero-title">{{ section.settings.heading }}</h1>
      <p class="bk-hero-lead">{{ section.settings.body }}</p>
      <div class="bk-actions">
        <a class="bk-btn" href="{{ section.settings.primary_url }}">{{ section.settings.primary_label }}</a>
        <a class="bk-btn bk-btn--green" href="{{ section.settings.secondary_url }}">{{ section.settings.secondary_label }}</a>
        <a class="bk-btn bk-btn--dark" href="{{ section.settings.tertiary_url }}">{{ section.settings.tertiary_label }}</a>
      </div>
    </div>
    <div class="bk-hero-art">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1100 | image_tag: loading: 'eager', alt: section.settings.heading }}
      {% else %}
        <div class="bk-product-stack"><span class="bk-spice-swoosh"></span><div class="bk-bottle"><div class="bk-label">Island<br>Gold<small>Briscoe's Kitchen & Spice</small></div></div></div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .bk-hero-product-drop{border-bottom:6px solid #050505;color:#fff;background-color:#050505;}
  #shopify-section-{{ section.id }} .bk-hero-grid{min-height:600px;display:grid;grid-template-columns:minmax(0,1fr) minmax(340px,.86fr);align-items:center;}
  #shopify-section-{{ section.id }} .bk-hero-copy{padding:clamp(34px,6vw,76px) 0;}
  #shopify-section-{{ section.id }} .bk-hero-title{max-width:820px;margin-top:12px;color:#fff;font-size:clamp(56px,8.6vw,124px);line-height:.78;text-transform:uppercase;text-shadow:0 6px 0 rgba(0,0,0,.7),0 16px 30px rgba(0,0,0,.6);}
  #shopify-section-{{ section.id }} .bk-hero-title strong{display:block;color:#ffb900;font-family:Georgia,"Times New Roman",serif;font-style:italic;font-weight:900;line-height:.9;text-transform:none;}
  #shopify-section-{{ section.id }} .bk-hero-lead{max-width:700px;margin-top:18px;color:#ffd050;font-family:Arial,sans-serif;font-size:clamp(18px,1.8vw,27px);line-height:1.2;font-weight:900;}
  #shopify-section-{{ section.id }} .bk-hero-art{min-height:520px;display:grid;place-items:center;padding:44px 24px;overflow:hidden;}
  #shopify-section-{{ section.id }} .bk-hero-art img{width:100%;height:100%;object-fit:cover;display:block;}
  #shopify-section-{{ section.id }} .bk-product-stack{position:relative;width:min(430px,78vw);aspect-ratio:1/1.08;display:grid;place-items:center;}
  #shopify-section-{{ section.id }} .bk-spice-swoosh{position:absolute;width:118%;height:42%;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.9) 0 1px,transparent 2px) 0 0/22px 22px,linear-gradient(90deg,transparent,#f16d12 22%,#ffb900 54%,transparent);filter:drop-shadow(0 0 12px rgba(255,203,5,.68));transform:rotate(-18deg);}
  #shopify-section-{{ section.id }} .bk-bottle{position:relative;width:min(190px,42vw);height:360px;border:4px solid #050505;border-radius:20px 20px 32px 32px;background:linear-gradient(90deg,rgba(255,255,255,.36),transparent 20% 70%,rgba(0,0,0,.22)),repeating-linear-gradient(0deg,#c86b18 0 6px,#f5a82a 6px 12px);box-shadow:22px 30px 0 rgba(0,0,0,.38),0 0 38px rgba(255,203,5,.36);overflow:hidden;transform:rotate(12deg);}
  #shopify-section-{{ section.id }} .bk-label{position:absolute;left:14px;right:14px;top:106px;min-height:150px;display:grid;place-items:center;padding:12px 8px;border:4px solid #050505;background:linear-gradient(34deg,transparent 0 43%,#ffb900 43% 49%,transparent 49% 51%,#ffb900 51% 57%,transparent 57%),linear-gradient(146deg,#007a3d 0 48%,#050505 48% 52%,#007a3d 52% 100%);color:#ffb900;text-align:center;text-transform:uppercase;font-size:36px;line-height:.82;text-shadow:2px 2px 0 #050505;}
  #shopify-section-{{ section.id }} .bk-label small{display:block;margin-top:7px;color:#fff;font-size:13px;}
  @media(max-width:990px){#shopify-section-{{ section.id }} .bk-hero-grid{grid-template-columns:1fr;}#shopify-section-{{ section.id }} .bk-hero-art{min-height:auto;}}
</style>

{% schema %}
{"name":"BK Hero Product Drop","tag":"section","settings":[{"type":"text","id":"kicker","label":"Eyebrow","default":"Official Product Shop"},{"type":"inline_richtext","id":"heading","label":"Heading","default":"Bold Island Flavor. <strong>Shipped From The U.S.</strong>"},{"type":"textarea","id":"body","label":"Body copy","default":"Shop the official Briscoe's Kitchen & Spice product drop featuring Island Gold All-Purpose Seasoning, bundles, and select flavor essentials. Bring big flavor to everyday meals, family gatherings, cookouts, events, and weekend plates."},{"type":"image_picker","id":"image","label":"Hero image"},{"type":"text","id":"primary_label","label":"Primary button label","default":"Shop Island Gold"},{"type":"url","id":"primary_url","label":"Primary button URL"},{"type":"text","id":"secondary_label","label":"Secondary button label","default":"Explore Recipes"},{"type":"url","id":"secondary_url","label":"Secondary button URL"},{"type":"text","id":"tertiary_label","label":"Tertiary button label","default":"Book Catering"},{"type":"url","id":"tertiary_url","label":"Tertiary button URL"}],"presets":[{"name":"BK Hero Product Drop"}]}
{% endschema %}
