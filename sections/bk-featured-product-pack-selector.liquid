<section class="bk-section bk-featured-product" style="background:#f7f2e8;color:#111;padding:58px 0;border-top:6px solid #050505;">
  <div class="bk-wrap bk-featured-grid">
    <div class="bk-product-media">
      {% assign product_ref = section.settings.product %}
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {% elsif product_ref != blank and product_ref.featured_image != blank %}
        {{ product_ref.featured_image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: product_ref.title }}
      {% else %}
        <div class="bk-mark" style="width:120px;height:120px;font-size:42px;">IG</div>
      {% endif %}
    </div>
    <div>
      <p class="bk-kicker" style="color:#007a3d;">{{ section.settings.kicker }}</p>
      <h2 class="bk-product-title">{% if product_ref != blank %}{{ product_ref.title }}{% else %}{{ section.settings.heading }}{% endif %}</h2>
      <span class="bk-underline"></span>
      <div class="bk-product-sub">{{ section.settings.subtitle }}</div>
      {% if section.settings.review_label != blank %}<div class="bk-review">★★★★★ <span>{{ section.settings.review_label }}</span></div>{% endif %}
      <div class="bk-price">{{ section.settings.price_label }}</div>
      <p class="bk-body">{{ section.settings.body }}</p>
      <span class="bk-pack-label">{{ section.settings.pack_label }}</span>
      <div class="bk-pack-grid">
        {% for block in section.blocks %}
          <a class="bk-pack-card" href="{{ block.settings.url | default: section.settings.shop_url }}" {{ block.shopify_attributes }}><strong>{{ block.settings.title }}</strong><span>{{ block.settings.description }}</span><em>{{ block.settings.price }}</em></a>
        {% endfor %}
      </div>
      {% if product_ref != blank %}
        {% form 'product', product_ref %}
          <div class="bk-buy-row">
            <select class="bk-variant-select" name="id" aria-label="Choose variant">
              {% for variant in product_ref.variants %}<option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>{{ variant.title }} - {{ variant.price | money }}</option>{% endfor %}
            </select>
            <input class="bk-qty" type="number" name="quantity" min="1" value="1" aria-label="Quantity">
            <button class="bk-cart-btn" type="submit">Add To Cart</button>
          </div>
        {% endform %}
      {% else %}
        <div class="bk-actions"><a class="bk-btn" href="{{ section.settings.shop_url }}">Shop Products</a></div>
      {% endif %}
      <p class="bk-body" style="margin-top:14px;color:#007a3d;">{{ section.settings.shipping_note }}</p>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .bk-featured-grid{display:grid;grid-template-columns:minmax(320px,.95fr) minmax(320px,1fr);gap:36px;align-items:start;}
  #shopify-section-{{ section.id }} .bk-product-media{min-height:440px;display:grid;place-items:center;border:4px solid #050505;border-radius:10px;background:radial-gradient(circle at 30% 35%,rgba(255,203,5,.4),transparent 24%),linear-gradient(34deg,transparent 0 43%,#ffb900 43% 48%,transparent 48% 52%,#ffb900 52% 57%,transparent 57%),#f5e6be;overflow:hidden;}
  #shopify-section-{{ section.id }} .bk-product-media img{width:100%;height:100%;object-fit:cover;display:block;}
  #shopify-section-{{ section.id }} .bk-product-title{margin-top:4px;color:#050505;font-size:clamp(50px,5.6vw,82px);line-height:.82;text-transform:uppercase;text-shadow:0 3px 0 rgba(255,203,5,.55);}
  #shopify-section-{{ section.id }} .bk-underline{display:block;width:min(520px,100%);height:10px;margin:8px 0 6px;border-radius:999px;background:#ffb900;}
  #shopify-section-{{ section.id }} .bk-product-sub{color:#007a3d;font-family:Georgia,"Times New Roman",serif;font-style:italic;font-size:clamp(26px,3vw,40px);line-height:1;font-weight:900;}
  #shopify-section-{{ section.id }} .bk-review{margin-top:10px;color:#d89b00;font-family:Arial,sans-serif;font-size:18px;font-weight:900;}#shopify-section-{{ section.id }} .bk-review span{color:#050505;font-size:15px;}
  #shopify-section-{{ section.id }} .bk-price{margin-top:8px;color:#050505;font-size:clamp(42px,5vw,62px);line-height:.9;}
  #shopify-section-{{ section.id }} .bk-pack-label{display:block;margin-top:18px;color:#050505;font-size:20px;text-transform:uppercase;}
  #shopify-section-{{ section.id }} .bk-pack-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:8px;}
  #shopify-section-{{ section.id }} .bk-pack-card{min-height:96px;display:grid;place-items:center;padding:10px 12px;border:4px solid #050505;border-radius:16px;background:#f7f2e8;color:#050505;text-align:center;font-size:20px;line-height:.96;box-shadow:0 4px 0 rgba(0,0,0,.2);text-decoration:none;text-transform:uppercase;}
  #shopify-section-{{ section.id }} .bk-pack-card:nth-child(2){background:#007a3d;color:#fff;}#shopify-section-{{ section.id }} .bk-pack-card:nth-child(3){background:#ffb900;}
  #shopify-section-{{ section.id }} .bk-pack-card span,#shopify-section-{{ section.id }} .bk-pack-card em{display:block;margin-top:6px;font-family:Arial,sans-serif;font-size:13px;line-height:1.1;font-weight:900;text-transform:none;font-style:normal;}
  #shopify-section-{{ section.id }} .bk-buy-row{display:grid;grid-template-columns:minmax(0,1fr) 100px minmax(160px,.7fr);gap:12px;margin-top:16px;}
  #shopify-section-{{ section.id }} .bk-variant-select,#shopify-section-{{ section.id }} .bk-qty{min-height:58px;border:4px solid #050505;border-radius:8px;background:#fff;color:#050505;font:900 18px/1 Arial,sans-serif;padding:0 12px;}
  #shopify-section-{{ section.id }} .bk-cart-btn{min-height:58px;display:grid;place-items:center;border:4px solid #050505;border-radius:8px;background:#007a3d;color:#ffb900;box-shadow:0 5px 0 #050505;font:inherit;font-size:clamp(20px,2.3vw,30px);line-height:.95;text-transform:uppercase;text-decoration:none;}
  @media(max-width:990px){#shopify-section-{{ section.id }} .bk-featured-grid{grid-template-columns:1fr;}#shopify-section-{{ section.id }} .bk-pack-grid,#shopify-section-{{ section.id }} .bk-buy-row{grid-template-columns:1fr;}}
</style>

{% schema %}
{"name":"BK Featured Product","tag":"section","settings":[{"type":"product","id":"product","label":"Featured product"},{"type":"image_picker","id":"image","label":"Image override"},{"type":"text","id":"kicker","label":"Kicker","default":"Featured Drop"},{"type":"text","id":"heading","label":"Fallback heading","default":"Island Gold All-Purpose Seasoning"},{"type":"text","id":"subtitle","label":"Subtitle","default":"All-Purpose Seasoning - 5 oz"},{"type":"text","id":"review_label","label":"Review label","default":"Fan-favorite drop"},{"type":"text","id":"price_label","label":"Price label","default":"Starting at $9.99"},{"type":"textarea","id":"body","label":"Body","default":"Bold island-inspired flavor made for chicken, fish, shrimp, vegetables, rice and peas, soups, eggs, fries, grilled dishes, marinades, and everyday cooking."},{"type":"text","id":"pack_label","label":"Pack label","default":"Choose Your Pack"},{"type":"textarea","id":"shipping_note","label":"Shipping note","default":"Ships from the United States. Selected international shipping is available where supported."},{"type":"url","id":"shop_url","label":"Shop URL"}],"blocks":[{"type":"pack","name":"Pack option","settings":[{"type":"text","id":"title","label":"Title","default":"Single Bottle"},{"type":"text","id":"description","label":"Description","default":"Perfect for first-time flavor lovers."},{"type":"text","id":"price","label":"Price","default":"$9.99"},{"type":"url","id":"url","label":"URL"}]}],"presets":[{"name":"BK Featured Product","blocks":[{"type":"pack","settings":{"title":"Single Bottle","description":"Perfect for first-time flavor lovers.","price":"$9.99"}},{"type":"pack","settings":{"title":"2-Pack","description":"Great for flavor lovers and gifting.","price":"$14.99"}},{"type":"pack","settings":{"title":"3-Pack","description":"Stock up for kitchen, cookouts, and family meals.","price":"$24.99"}}]}]}
{% endschema %}
