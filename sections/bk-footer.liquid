<footer class="bk-section" style="background:#050505;color:#ffd050;padding:48px 0 88px;border-top:6px solid #050505;">
  <div class="bk-wrap bk-footer-grid">
    <div>
      <a class="bk-logo" href="{{ routes.root_url }}">{% if section.settings.logo != blank %}{{ section.settings.logo | image_url: width: 320 | image_tag: loading: 'lazy', alt: section.settings.brand_name }}{% else %}<span class="bk-mark">{{ section.settings.logo_mark }}</span><span>{{ section.settings.brand_name }}</span>{% endif %}</a>
      <p class="bk-body" style="margin-top:14px;color:#f7f2e8;">{{ section.settings.description }}</p>
    </div>
    {% for block in section.blocks %}<div {{ block.shopify_attributes }}><h3>{{ block.settings.heading }}</h3>{% if block.settings.menu != blank %}{% for link in block.settings.menu.links %}<a href="{{ link.url }}">{{ link.title }}</a>{% endfor %}{% else %}<a href="{{ block.settings.link_1_url }}">{{ block.settings.link_1_label }}</a><a href="{{ block.settings.link_2_url }}">{{ block.settings.link_2_label }}</a><a href="{{ block.settings.link_3_url }}">{{ block.settings.link_3_label }}</a>{% endif %}</div>{% endfor %}
  </div>
</footer>
<style>#shopify-section-{{ section.id }} .bk-footer-grid{display:grid;grid-template-columns:1.25fr repeat(3,1fr);gap:28px;}#shopify-section-{{ section.id }} h3{color:#ffb900;font-size:28px;line-height:1;text-transform:uppercase;margin:0 0 14px;}#shopify-section-{{ section.id }} a{display:block;color:#f7f2e8;text-decoration:none;font-family:Arial,sans-serif;font-weight:900;margin:0 0 10px;}@media(max-width:900px){#shopify-section-{{ section.id }} .bk-footer-grid{grid-template-columns:1fr 1fr;}}@media(max-width:640px){#shopify-section-{{ section.id }} .bk-footer-grid{grid-template-columns:1fr;}}</style>
{% schema %}
{"name":"BK Footer","tag":"section","settings":[{"type":"image_picker","id":"logo","label":"Footer logo"},{"type":"text","id":"brand_name","label":"Brand name","default":"Briscoe's Kitchen & Spice"},{"type":"text","id":"logo_mark","label":"Fallback mark","default":"B"},{"type":"textarea","id":"description","label":"Description","default":"Official product shop for Briscoe's Kitchen & Spice seasonings, bundles, and select flavor drops."}],"blocks":[{"type":"column","name":"Footer column","settings":[{"type":"text","id":"heading","label":"Heading","default":"Shop"},{"type":"link_list","id":"menu","label":"Menu"},{"type":"text","id":"link_1_label","label":"Link 1 label","default":"Products"},{"type":"url","id":"link_1_url","label":"Link 1 URL"},{"type":"text","id":"link_2_label","label":"Link 2 label","default":"Bundles"},{"type":"url","id":"link_2_url","label":"Link 2 URL"},{"type":"text","id":"link_3_label","label":"Link 3 label","default":"Cart"},{"type":"url","id":"link_3_url","label":"Link 3 URL"}]}],"presets":[{"name":"BK Footer","blocks":[{"type":"column","settings":{"heading":"Shop","link_1_label":"Products","link_2_label":"Bundles","link_3_label":"Cart"}},{"type":"column","settings":{"heading":"Explore","link_1_label":"Recipes","link_2_label":"Catering","link_3_label":"Brand Partnerships"}},{"type":"column","settings":{"heading":"Support","link_1_label":"Contact","link_2_label":"Shipping Policy","link_3_label":"Refund Policy"}}]}]}
{% endschema %}
