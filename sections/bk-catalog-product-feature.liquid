<section class="bk-section bk-catalog-feature" style="background:{{ section.settings.background }};color:{{ section.settings.text_color }};padding:58px 0;border-top:6px solid #050505;">
  {% assign feature_product = section.settings.product %}
  <div class="bk-wrap bk-catalog-feature-grid">
    <div class="bk-catalog-feature-media">
      {% if feature_product != blank and feature_product.featured_image != blank %}
        {{ feature_product.featured_image | image_url: width: 1100 | image_tag: loading: 'lazy', alt: feature_product.featured_image.alt | default: feature_product.title }}
      {% elsif section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1100 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {% else %}
        <div class="bk-product-card-placeholder">BK</div>
      {% endif %}
    </div>
    <div class="bk-catalog-feature-copy">
      <p class="bk-kicker" style="color:{{ section.settings.kicker_color }};">{{ section.settings.kicker }}</p>
      <h2 class="bk-title">{% if feature_product != blank %}{{ feature_product.title }}{% else %}{{ section.settings.heading }}{% endif %}</h2>
      <p class="bk-body" style="margin-top:14px;color:{{ section.settings.body_color }};">{% if feature_product != blank and section.settings.use_product_description %}{{ feature_product.description | strip_html | truncate: 280 }}{% else %}{{ section.settings.body }}{% endif %}</p>
      {% if feature_product != blank %}<div class="bk-catalog-feature-price">{% if feature_product.price_varies %}From {{ feature_product.price_min | money }}{% else %}{{ feature_product.price | money }}{% endif %}</div>{% endif %}
      <div class="bk-actions">
        <a class="bk-btn" href="{% if feature_product != blank %}{{ feature_product.url }}{% else %}{{ section.settings.primary_url }}{% endif %}">{{ section.settings.primary_label }}</a>
        {% if section.settings.secondary_label != blank %}<a class="bk-btn bk-btn--green" href="{{ section.settings.secondary_url }}">{{ section.settings.secondary_label }}</a>{% endif %}
      </div>
    </div>
  </div>
</section>
<style>
  #shopify-section-{{ section.id }} .bk-catalog-feature-grid{display:grid;grid-template-columns:minmax(320px,.9fr) minmax(320px,1fr);gap:36px;align-items:center;}
  #shopify-section-{{ section.id }} .bk-catalog-feature-media{min-height:440px;display:grid;place-items:center;border:5px solid #050505;border-radius:14px;overflow:hidden;background:radial-gradient(circle at 30% 35%,rgba(255,185,0,.42),transparent 24%),#f5e6be;box-shadow:0 8px 0 rgba(0,0,0,.32);}
  #shopify-section-{{ section.id }} .bk-catalog-feature-media img{width:100%;height:100%;object-fit:cover;display:block;}
  #shopify-section-{{ section.id }} .bk-catalog-feature-price{margin-top:16px;color:#ffb900;font-size:clamp(38px,5vw,62px);line-height:.9;text-shadow:2px 2px 0 #050505;}
  @media(max-width:900px){#shopify-section-{{ section.id }} .bk-catalog-feature-grid{grid-template-columns:1fr;}}
</style>
{% schema %}
{"name":"BK Catalog Product Feature","tag":"section","settings":[{"type":"product","id":"product","label":"Product"},{"type":"image_picker","id":"image","label":"Optional fallback image"},{"type":"checkbox","id":"use_product_description","label":"Use Shopify product description","default":true},{"type":"text","id":"kicker","label":"Kicker","default":"Featured Product"},{"type":"text","id":"heading","label":"Fallback heading","default":"Briscoe Featured Product"},{"type":"textarea","id":"body","label":"Fallback body","default":"A featured Briscoe product powered by the Shopify catalog."},{"type":"text","id":"primary_label","label":"Primary label","default":"View Product"},{"type":"url","id":"primary_url","label":"Primary URL"},{"type":"text","id":"secondary_label","label":"Secondary label","default":"Shop The Collection"},{"type":"url","id":"secondary_url","label":"Secondary URL"},{"type":"color","id":"background","label":"Background","default":"#050505"},{"type":"color","id":"text_color","label":"Text color","default":"#ffffff"},{"type":"color","id":"kicker_color","label":"Kicker color","default":"#ffb900"},{"type":"color","id":"body_color","label":"Body color","default":"#ffd050"}],"presets":[{"name":"BK Catalog Product Feature"}]}
{% endschema %}
