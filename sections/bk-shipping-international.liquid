<section class="bk-section" style="background:#f7f2e8;color:#111;padding:58px 0;border-top:6px solid #050505;">
  <div class="bk-wrap">
    <p class="bk-kicker" style="color:#007a3d;">{{ section.settings.kicker }}</p>
    <h2 class="bk-title" style="color:#050505;">{{ section.settings.heading }}</h2>
    <p class="bk-body" style="max-width:900px;margin-top:14px;">{{ section.settings.body }}</p>
    <div class="bk-detail-grid">{% for block in section.blocks %}<div class="bk-detail" {{ block.shopify_attributes }}><h3>{{ block.settings.heading }}</h3><p>{{ block.settings.text }}</p></div>{% endfor %}</div>
  </div>
</section>
{% schema %}
{"name":"BK Shipping International","tag":"section","settings":[{"type":"text","id":"kicker","label":"Kicker","default":"Shipping"},{"type":"text","id":"heading","label":"Heading","default":"Flavor Shipped From The U.S."},{"type":"textarea","id":"body","label":"Body","default":"Orders ship from the United States. Selected international shipping is available where supported. Rates, duties, taxes, and delivery timelines may vary by destination."}],"blocks":[{"type":"note","name":"Shipping note","settings":[{"type":"text","id":"heading","label":"Heading","default":"U.S. Shipping"},{"type":"textarea","id":"text","label":"Text","default":"Domestic orders are prepared for direct product checkout and shipping."}]}],"presets":[{"name":"BK Shipping International","blocks":[{"type":"note","settings":{"heading":"U.S. Shipping","text":"Domestic orders are prepared for direct product checkout and shipping."}},{"type":"note","settings":{"heading":"International Orders","text":"Selected international shipping is available where supported by the checkout and carrier rules."}},{"type":"note","settings":{"heading":"Tracking","text":"Tracking details are sent after fulfillment when available."}}]}]}
{% endschema %}
