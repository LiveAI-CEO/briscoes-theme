<section class="bk-section bk-announcement-bar">
  <div class="bk-wrap">
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
    {% else %}
      {{ section.settings.text }}
    {% endif %}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} .bk-announcement-bar {
    background: #050505;
    color: #ffb900;
    text-align: center;
    padding: 10px 16px;
    border-bottom: 4px solid #050505;
    font-size: clamp(18px, 2.4vw, 30px);
    line-height: .95;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .bk-announcement-bar a { color: inherit; text-decoration: none; }
</style>

{% schema %}
{"name":"BK Announcement Bar","tag":"section","settings":[{"type":"text","id":"text","label":"Announcement text","default":"Island Gold is back - shop the official product drop."},{"type":"url","id":"link","label":"Optional link"}],"presets":[{"name":"BK Announcement Bar"}]}
{% endschema %}
