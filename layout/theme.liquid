<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#070706">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  <!-- Basic Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:title" content="{{ page_title }}">
  {% if page_description %}
    <meta property="og:description" content="{{ page_description | escape }}">
  {% endif %}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}

  <!-- Placeholder for future theme JS -->
  {{ 'theme.js' | asset_url | script_tag }}
</head>

<body>
  <!-- Skip to content for accessibility + mobile -->
  <a href="#MainContent" class="skip-link visually-hidden-focusable">
    Skip to main content
  </a>

  {% comment %}
    Mobile-first ready base layout.
    Add {% section 'header' %} or snippet here when you build the mobile nav.
  {% endcomment %}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% comment %}
    Footer include placeholder
  {% endcomment %}
</body>
</html>