<section style="min-height: 100vh; display: grid; place-items: center; padding: 48px 20px; background: #070706; color: #fff8df; text-align: center;">
  <div style="width: min(560px, 100%);">
    <p style="margin: 0 0 12px; color: #fed100; font-weight: 900; text-transform: uppercase;">Briscoe's Kitchen & Spice</p>
    <h1 style="margin: 0; font-size: clamp(40px, 8vw, 78px); line-height: .95; text-transform: uppercase;">Opening Soon</h1>
    <p style="margin: 18px 0 0; font-size: 18px; line-height: 1.5;">Bold catering, signature spices, classes, and The One Pot Family are almost ready.</p>

    {% form 'storefront_password', style: 'margin-top: 28px; display: grid; gap: 12px;' %}
      {{ form.errors | default_errors }}
      <input type="password" name="password" placeholder="Store password" style="min-height: 48px; padding: 12px; border: 1px solid #fed100; background: rgba(255,255,255,.08); color: #fff8df;">
      <button type="submit" style="min-height: 48px; border: 0; background: #fed100; color: #070706; font-weight: 900; text-transform: uppercase;">Enter</button>
    {% endform %}
  </div>
</section>
