<section style="min-height: 100vh; display: grid; place-items: center; padding: 48px 20px; background: #070706; color: #fff8df; text-align: center;">
  <div style="width: min(680px, 100%); border: 1px solid rgba(254,209,0,.4); padding: 32px;">
    <p style="margin: 0 0 12px; color: #fed100; font-weight: 900; text-transform: uppercase;">Gift Card</p>
    <h1 style="margin: 0; font-size: clamp(36px, 7vw, 64px); line-height: .98; text-transform: uppercase;">{{ gift_card.initial_value | money }}</h1>
    <p style="margin: 18px 0 0; font-size: 18px; line-height: 1.5;">Use this gift card toward Chef Briscoe products where eligible.</p>
    <p style="margin: 18px 0 0; font-size: 20px; color: #fed100; font-weight: 900; letter-spacing: .08em;">{{ gift_card.code | format_code }}</p>
  </div>
</section>
